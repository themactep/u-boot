CONFIG_MIPS=y
CONFIG_TEXT_BASE=0x80100000
CONFIG_SYS_MALLOC_LEN=0x2000000
CONFIG_SYS_BOOTM_LEN=0x2000000
CONFIG_NR_DRAM_BANKS=1
CONFIG_DEFAULT_DEVICE_TREE="t32-isvp"
CONFIG_SYS_LOAD_ADDR=0x82000000
CONFIG_ARCH_XBURST=y
CONFIG_SOC_T32=y
CONFIG_TARGET_ISVP_T32=y
CONFIG_SPL=y
CONFIG_SPL_FRAMEWORK=y
# T32's SPL is larger than the legacy-DDRC SoCs (uMCTL2 DDR +
# Innophy soft-train + SFC2 + LZMA): give it room. QEMU presents
# DRAM at 0x80000000 from reset so this all fits; fitting a real
# T32's on-chip SRAM is a separate concern (no T32 silicon yet -
# QEMU-NOR is the only validation path).
CONFIG_SPL_TEXT_BASE=0x80001000
CONFIG_SPL_MAX_SIZE=0x8000
CONFIG_SPL_BSS_START_ADDR=0x80009000
CONFIG_SPL_BSS_MAX_SIZE=0x2000
# CONFIG_SPL_SHARES_INIT_SP_ADDR is not set
CONFIG_SPL_HAVE_INIT_STACK=y
CONFIG_SPL_STACK=0x8000c000
CONFIG_SPL_LIBGENERIC_SUPPORT=y
CONFIG_SPL_LIBCOMMON_SUPPORT=y
CONFIG_SPL_SYS_MALLOC=y
CONFIG_BUILD_TARGET="u-boot-lzma.img"
CONFIG_LZMA=y
CONFIG_SPL_LZMA=y
CONFIG_SPL_LZMA_SIZE_OPTIMIZATION=y
CONFIG_SYS_MIPS_TIMER_FREQ=900000000
CONFIG_SKIP_LOWLEVEL_INIT=y
CONFIG_DISPLAY_CPUINFO=y
CONFIG_BOARD_INIT=y
CONFIG_OF_CONTROL=y
CONFIG_DM=y
CONFIG_DM_SERIAL=y
CONFIG_SYS_NS16550=y
CONFIG_BAUDRATE=115200
CONFIG_FIT=y
CONFIG_BOOTDELAY=2
CONFIG_DISPLAY_BOARDINFO=y
CONFIG_CMD_GPIO=y
CONFIG_CLK=y
CONFIG_CLK_INGENIC_T32=y
CONFIG_DM_GPIO=y
CONFIG_PINCTRL=y
CONFIG_PINCTRL_INGENIC=y
CONFIG_SYSRESET=y
CONFIG_SYSRESET_WATCHDOG=y
CONFIG_SYSRESET_WATCHDOG_AUTO=y
CONFIG_WDT=y
CONFIG_WDT_INGENIC=y
# CONFIG_WATCHDOG is not set
# CONFIG_WATCHDOG_AUTOSTART is not set
CONFIG_ENV_IS_NOWHERE=y

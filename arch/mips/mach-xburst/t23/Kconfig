if SOC_T23

choice
	prompt "T23 SoC variant"
	default T23_VARIANT_T23N
	help
	  Specific T23 product variant. T23 is XBurst1/Innophy-DDR2
	  like T31, but no T23 board is 128 MB: T23/T23N/T23X use the
	  64 MB DDR2 M14D5121632A (4-bank), T23DL/T23DN the 32 MB
	  M14D2561616A. Variants differ in the APLL (CPU) clock and
	  the DRAM part. The CPAPCR M/N/OD encodings below are the
	  exact vendor isvp_common.h CONFIG_SYS_APLL_MNOD values
	  (non-uniform N/OD - do not recompute, the vendor numbers are
	  authoritative).

config T23_VARIANT_T23DL
	bool "T23DL (CPU 1188 MHz, 32 MB)"

config T23_VARIANT_T23DN
	bool "T23DN (CPU 1000 MHz, 32 MB)"

config T23_VARIANT_T23N
	bool "T23N (CPU 1188 MHz, 64 MB)"

config T23_VARIANT_T23N_HP
	bool "T23N-HP (CPU 1400 MHz, 64 MB)"

config T23_VARIANT_T23N_LP
	bool "T23N-LP (CPU 936 MHz, 64 MB)"

config T23_VARIANT_T23X
	bool "T23X / T23 base (CPU 1000 MHz, 64 MB)"

config T23_VARIANT_T23ZN
	bool "T23ZN (CPU 1188 MHz, 64 MB)"

endchoice

config T23_VARIANT_NAME
	string
	default "T23DL"   if T23_VARIANT_T23DL
	default "T23DN"   if T23_VARIANT_T23DN
	default "T23N-HP" if T23_VARIANT_T23N_HP
	default "T23N-LP" if T23_VARIANT_T23N_LP
	default "T23X"    if T23_VARIANT_T23X
	default "T23ZN"   if T23_VARIANT_T23ZN
	default "T23N"

config T23_DRAM_32M
	bool
	default y if T23_VARIANT_T23DL || T23_VARIANT_T23DN
	help
	  T23DL/T23DN populate the 32 MB DDR2 M14D2561616A (row 13,
	  col 9, 4-bank). All other T23 variants use the 64 MB
	  M14D5121632A (row 13, col 10, 4-bank). Selects the matching
	  DDRC_CFG/MMAP geometry in mach/t23-ddr.h. No 128 MB option:
	  no T23 board ships 128 MB.

config T23_APLL_MNOD
	hex
	default 0x1290d100 if T23_VARIANT_T23DL
	default 0x07d05900 if T23_VARIANT_T23DN
	default 0x15e0d100 if T23_VARIANT_T23N_HP
	default 0x0ea0d100 if T23_VARIANT_T23N_LP
	default 0x07d05900 if T23_VARIANT_T23X
	default 0x1290d100
	help
	  CPAPCR value = (M<<20)|(N<<14)|(OD1<<11)|(OD0<<8), exact
	  vendor CONFIG_SYS_APLL_MNOD: 1400=(350,3,2,1)=0x15e0d100,
	  1188=(297,3,2,1)=0x1290d100, 1000=(125,1,3,1)=0x07d05900,
	  936=(234,3,2,1)=0x0ea0d100. T23N/T23ZN take the bare 1188
	  default. Each variant now also runs its vendor-native DDR
	  clock (see T23_MPLL_MNOD / T23_DDR_MHZ below).

config T23_MPLL_MNOD
	hex
	default 0x07d05900 if T23_VARIANT_T23X || T23_VARIANT_T23DN
	default 0x06405100
	help
	  CPMPCR value, exact vendor CONFIG_SYS_MPLL_MNOD. T23N/ZN/
	  HP/LP/DL run MPLL 1200 (0x06405100); T23X/T23DN run the
	  bare-T23 DDR_500M profile MPLL 1000 (0x07d05900). DDR =
	  MPLL / (T23_DDR_MHZ-derived divider).

config T23_DDR_MHZ
	int
	default 400 if T23_VARIANT_T23N_LP
	default 500 if T23_VARIANT_T23X || T23_VARIANT_T23DN
	default 600
	help
	  Vendor-native DDR data rate (MHz) for the variant:
	  T23N/ZN/HP/DL 600 (MPLL 1200 / 2); T23N-LP 400 (MPLL
	  1200 / 3); T23X/T23DN 500 (MPLL 1000 / 2). Selects
	  DDR_TARGET_RATE and the clock-dependent DDR2 timing set
	  (mach/t23-ddr.h); t23/pll.c uses the MPLL-1000 group's
	  vendor DDR_500M CPCCR dividers (PCLK 8 / H2 4 / H0 4) vs
	  the 1200-group's PCLK 12 / H2 6 / H0 6.

config SPL_T23_USB_BOOT
	bool "T23 SPL: return to mask ROM for USB boot (dev loop)"
	depends on SPL
	help
	  Build the SPL as a mask-ROM USB-boot stage1: bring up the
	  clocks (and DDR once ported), then return to the bootrom
	  (jr ra) instead of loading U-Boot proper from SPI-NOR. The
	  T23N is bootrom-only on the lab rig, so this is how the SPL
	  is brought up and tested. Development only.

endif

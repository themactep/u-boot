if SOC_T10

# T10 has the DesignWare (DWC) DDR2 PHY (same family as T20, not the Innophy
# core of T21/T23/T30/T31) and reuses drivers/ram/ingenic/ddr_t20.c. The per-SKU
# PLL setpoints (the APLL/CPU clock differs between T10N 860 and T10L 712) and
# the DDR parameters come from the &ddr node's "ingenic,sdram-params" array in
# the leaf .dts, so there is no compile-time variant choice.

config SPL_T10_USB_BOOT
	bool "T10 SPL: return to mask ROM for USB boot (dev loop)"
	depends on SPL
	help
	  Build the SPL as a mask-ROM USB-boot stage1: bring up the
	  clocks (and DDR once ported), then return to the bootrom
	  (jr ra) instead of loading U-Boot proper from SPI-NOR -
	  how the SPL is brought up and tested on the lab rig.
	  Development only.

endif

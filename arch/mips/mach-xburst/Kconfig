menu "Ingenic XBurst T-series platforms"
	depends on ARCH_XBURST

config SYS_VENDOR
	default "ingenic"

config SYS_SOC
	default "a1" if SOC_A1
	default "t10" if SOC_T10
	default "t20" if SOC_T20
	default "t21" if SOC_T21
	default "t23" if SOC_T23
	default "t30" if SOC_T30
	default "t31" if SOC_T31
	default "t32" if SOC_T32
	default "t33" if SOC_T33
	default "t40" if SOC_T40
	default "t41" if SOC_T41

choice
	prompt "Ingenic SoC select"
	default SOC_T31

config SOC_A1
	bool "Ingenic A1 (XBurst2)"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select MIPS_L2_CACHE
	select BINMAN
	help
	  Ingenic A1 XBurst2 dual-core camera SoC: 24 MHz EXTAL,
	  APLL/MPLL/VPLL/EPLL, Innophy DDR3, SFC SPI-flash boot via
	  on-chip mask ROM. Variants: A1N (DDR3-800 256M 16-bit),
	  A1NT (DDR3-700), A1X (DDR3-700), A1L (DDR3-800 16-bit),
	  A1A (DDR3-800 APLL 1200).

config SOC_T10
	bool "Ingenic T10"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select BINMAN
	help
	  Ingenic T10 XBurst1 camera SoC: 24 MHz EXTAL, APLL/MPLL/VPLL,
	  DesignWare (DWC) DDR2 PHY (same family as T20), 64 MB
	  M14D5121632A, SFC SPI-flash boot via on-chip mask ROM. Same
	  XBurst1 base as T20; DWC DDR (not Innophy); 4 GPIO banks;
	  T10N APLL 860 / MPLL 1200 / DDR 400 (MEM_FREQ = MPLL/3).

config SOC_T20
	bool "Ingenic T20"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select BINMAN
	help
	  Ingenic T20 XBurst1 camera SoC: 24 MHz EXTAL, APLL/MPLL/VPLL,
	  DesignWare (DWC) DDR2 PHY, 64 MB M14D5121632A, SFC SPI-flash
	  boot via on-chip mask ROM. Same XBurst1 base as T31; DWC DDR (not Innophy);
	  3 GPIO banks; T20N APLL 860 / DDR 500.

config SOC_T21
	bool "Ingenic T21"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select BINMAN
	help
	  Ingenic T21 XBurst1 camera SoC: 24 MHz EXTAL, APLL/MPLL/VPLL,
	  Innophy DDR2 PHY (64 MB M14D5121632A like T23), SFC SPI-flash
	  boot via on-chip mask ROM. Same XBurst1 base as T31/T23;
	  differs in clock targets (APLL 864 / DDR 450).

config SOC_T23
	bool "Ingenic T23"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select BINMAN
	help
	  Ingenic T23 XBurst1 camera SoC: 24 MHz EXTAL, APLL/MPLL (no
	  VPLL), Innophy DDR2 PHY, SFC SPI-flash boot via on-chip mask
	  ROM. Same XBurst1 base as T31; differs in clock targets and
	  the DDR2 part.

config SOC_T30
	bool "Ingenic T30"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select BINMAN
	help
	  Ingenic T30 XBurst1 camera SoC: 24 MHz EXTAL, APLL/MPLL/VPLL,
	  Innophy DDR2 PHY (64 MB M14D5121632A like T21/T23), SFC SPI-flash
	  boot via on-chip mask ROM. Same XBurst1 base as T31/T23/T21;
	  differs in clock targets (APLL 864 / DDR 500).

config SOC_T31
	bool "Ingenic T31"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select BINMAN
	help
	  Ingenic T31 XBurst1 camera SoC: 24 MHz EXTAL, APLL/MPLL/VPLL,
	  Innophy DDR2/DDR3 PHY, SFC SPI-flash boot via on-chip mask ROM.

config SOC_T32
	bool "Ingenic T32"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select BINMAN
	help
	  Ingenic T32 (vendor PRJ007) XBurst1 "T31-extended" camera SoC:
	  24 MHz EXTAL, APLL/MPLL/VPLL, Innophy DDR (DDR2/DDR3/LPDDR3),
	  SFC2 SPI-flash boot via on-chip mask ROM. Forward-ported from
	  the modern U-Boot 2022.10 vendor branch. Runtime SOCID
	  0x10032004. (DDR2 M14D5121632A is the first supported part.)

config SOC_T33
	bool "Ingenic T33"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select BINMAN
	help
	  Ingenic T33 (vendor PRJ008) XBurst1 "T31-extended" camera SoC:
	  24 MHz EXTAL, APLL/MPLL, Innophy DDR (DDR2/DDR3/LPDDR3), SFC
	  SPI-flash boot via on-chip mask ROM. Forward-ported from the
	  modern U-Boot 2022.10 vendor branch. Runtime SOCID
	  0x10033004. (DDR2 M14D5121632A is the first supported part.)

config SOC_T40
	bool "Ingenic T40"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select MIPS_L2_CACHE
	select BINMAN
	help
	  Ingenic T40 XBurst2 dual-core camera SoC: 24 MHz EXTAL,
	  APLL/MPLL/EPLL/VPLL, Innophy DDR2/DDR3 PHY, SFC SPI-flash
	  boot via on-chip mask ROM. Sibling of A1 (XBurst2); single
	  OTG, Synopsys GMAC, SDHCI-style MSC. Variants: T40 (DDR2
	  64 MB M14D5121632A default), T40N/T40XP (DDR3).

config SOC_T41
	bool "Ingenic T41"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select MIPS_L2_CACHE
	select BINMAN
	help
	  Ingenic T41 XBurst2 dual-core camera SoC: 24 MHz EXTAL,
	  APLL/MPLL/EPLL/VPLL, Innophy DDR3 PHY (16-bit bus on most
	  variants - different from T40XP 32-bit). Same base addresses
	  as T40. Single OTG (DWC2), Synopsys GMAC, SDHCI-style MSC,
	  SFC SPI-flash boot. 13 variants in vendor source. Lab board
	  uses T41NQ: APLL=1104, MPLL=1400 (DDR=700), DDR3-W631GU6NG
	  128 MiB 16-bit, MX25L25645G 32 MiB SPI-NOR boot.

endchoice

source "arch/mips/mach-xburst/a1/Kconfig"
source "arch/mips/mach-xburst/t10/Kconfig"
source "arch/mips/mach-xburst/t20/Kconfig"
source "arch/mips/mach-xburst/t21/Kconfig"
source "arch/mips/mach-xburst/t23/Kconfig"
source "arch/mips/mach-xburst/t30/Kconfig"
source "arch/mips/mach-xburst/t31/Kconfig"
source "arch/mips/mach-xburst/t32/Kconfig"
source "arch/mips/mach-xburst/t33/Kconfig"
source "arch/mips/mach-xburst/t40/Kconfig"
source "arch/mips/mach-xburst/t41/Kconfig"

choice
	prompt "Board select"
	default TARGET_ISVP_T31

config TARGET_ISVP_A1
	bool "Ingenic ISVP-A1 reference board"
	select SOC_A1
	help
	  Ingenic ISVP A1 reference board, DDR3 256 MB, SFC NOR boot.

config TARGET_ISVP_T10
	bool "Ingenic ISVP-T10 reference board"
	select SOC_T10
	help
	  Ingenic ISVP T10 reference board, DDR2 64 MB, SFC NOR boot.

config TARGET_ISVP_T20
	bool "Ingenic ISVP-T20 reference board"
	select SOC_T20
	help
	  Ingenic ISVP T20 reference board, DDR2 64 MB, SFC NOR boot.

config TARGET_ISVP_T21
	bool "Ingenic ISVP-T21 reference board"
	select SOC_T21
	help
	  Ingenic ISVP T21 reference board, DDR2 64 MB, SFC NOR boot.

config TARGET_ISVP_T23
	bool "Ingenic ISVP-T23 reference board"
	select SOC_T23
	help
	  Ingenic ISVP T23 reference board, DDR2 64 MB, SFC NOR boot.

config TARGET_ISVP_T30
	bool "Ingenic ISVP-T30 reference board"
	select SOC_T30
	help
	  Ingenic ISVP T30 reference board, DDR2 64 MB, SFC NOR boot.

config TARGET_ISVP_T31
	bool "Ingenic ISVP-T31 reference board"
	select SOC_T31
	help
	  Ingenic ISVP T31 reference board, DDR2 128 MB, SFC NOR boot.

config TARGET_ISVP_T32
	bool "Ingenic ISVP-T32 reference board"
	select SOC_T32
	help
	  Ingenic ISVP T32 (PRJ007) reference board, DDR2
	  M14D5121632A, SFC NOR boot.

config TARGET_ISVP_T33
	bool "Ingenic ISVP-T33 reference board"
	select SOC_T33
	help
	  Ingenic ISVP T33 (PRJ008) reference board, DDR2
	  M14D5121632A, SFC NOR boot.

config TARGET_ISVP_T40
	bool "Ingenic ISVP-T40 reference board"
	select SOC_T40
	help
	  Ingenic ISVP T40 reference board, DDR2 M14D5121632A,
	  SFC NOR boot.

config TARGET_ISVP_T41
	bool "Ingenic ISVP-T41 reference board"
	select SOC_T41
	help
	  Ingenic ISVP T41 reference board, DDR3 W631GU6NG 16-bit
	  128 MiB, SFC NOR boot (MX25L25645G 32 MiB).

endchoice


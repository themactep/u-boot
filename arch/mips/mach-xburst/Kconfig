menu "Ingenic XBurst T-series platforms"
	depends on ARCH_XBURST

#
# XBurst1 T-series boot shape is dictated by one hardware fact: the
# mask-ROM SPI-NOR load cap. Two ROM generations exist in the family:
#
#   Capped (0x6800 = 26 KiB) - T10/T20/T21/T30. The gen-1/1.5 ROM loads
#     only the first 0x6800 bytes of the boot image, too small for the
#     DM SFC + spi-nor framework (~29 KiB on its own). These parts run a
#     tiny DDR-only TPL (cache-as-RAM) that brings up PLL + DRAM and
#     chain-loads a DRAM-resident SPL over a minimal 0x03 NOR read; the
#     full SPI framework then lives in that SPL. They select SUPPORT_TPL.
#
#   Uncapped - T23/T31. The later ROM loads the whole image, so these
#     keep a single big DM SPL (SPL_SPI) and need no TPL or hand-rolled
#     read.
#
# Either way the only per-SoC difference is DDR: the Innophy PHY
# (drivers/ram/ingenic/ddr_t31.c; T21/T23/T30/T31) or the Synopsys DWC
# PHY (ddr_t20.c; T10/T20), with the per-SKU register block supplied as
# the "ingenic,sdram-params" devicetree array. Everything below the
# bring-up shim is one shared codebase.
#
# This follows established U-Boot patterns: DDR-in-TPL via OF_PLATDATA
# (Rockchip rk3328) on a MIPS tpl/spl split (MediaTek mt7621). Bindings:
# doc/device-tree-bindings/memory-controllers/ingenic,t31-ddr-innophy.yaml
# and ingenic,t20-ddr-dwc.yaml.
#

config SYS_VENDOR
	default "ingenic"

config SYS_SOC
	default "a1" if SOC_A1
	default "t10" if SOC_T10
	default "t20" if SOC_T20
	default "t21" if SOC_T21
	default "t23" if SOC_T23
	default "t30" if SOC_T30
	default "t31" if SOC_T31
	default "t32" if SOC_T32
	default "t33" if SOC_T33
	default "t40" if SOC_T40
	default "t41" if SOC_T41

choice
	prompt "Ingenic SoC select"
	default SOC_T31

config SOC_A1
	bool "Ingenic A1 (XBurst2)"
	select SUPPORT_LITTLE_ENDIAN
	select SUPPORTS_CPU_MIPS32_R1
	select SUPPORTS_CPU_MIPS32_R2
	select SYS_CACHE_SHIFT_5
	select SYS_MIPS_CACHE_INIT_RAM_LOAD
	select MIPS_L2_CACHE
	select BINMAN
	help
	  Ingenic A1 XBurst2 dual-core camera SoC: 24 MHz EXTAL,
	  APLL/MPLL/VPLL/EPLL, Innophy DDR3, SFC SPI-flash boot via
	  on-chip mask ROM. Variants: A1N (DDR3-800 256M 16-bit),
	  A1NT (DDR3-700), A1X (DDR3-700), A1L (DDR3-800 16-bit),
	  A1A (DDR3-800 APLL 1200).


if SOC_T41

# The T41 SKU (DDR type/geometry/clocks) is selected at runtime from the
# devicetree: each leaf .dts sets a per-SKU compatible on &ddr and the
# drivers/ram/ingenic/ddr_innophy driver carries the setpoints in its
# of_match .data (same model as T31/T40/A1). No Kconfig variant.

config SPL_T41_USB_BOOT
	bool "T41 SPL: return to mask ROM for USB boot (dev loop)"
	depends on SPL
	help
	  Build the SPL as a mask-ROM USB-boot stage1: bring up the
	  PLLs and DDR, then return to the bootrom (jr ra) instead of
	  loading U-Boot proper from SPI-NOR. The mask ROM then uploads
	  U-Boot proper over USB. Used by the USB-boot / DFU loader
	  defconfigs (isvp_t41_usbboot_defconfig and
	  isvp_t41_usbboot_ddr3_defconfig).

endif

if SOC_T30

choice
	prompt "T30 SoC variant"
	default T30_VARIANT_T30L
	help
	  Specific T30 product variant. T30 is XBurst1/Innophy-DDR2
	  like T21 (cpm_cpxpcr_t PLL, VPLL) and uses the same 64 MB
	  DDR2 M14D5121632A (4-bank) at DDR 500 MHz; variants differ
	  in the APLL (CPU) clock. The CPAPCR M/N/OD encodings are
	  the exact vendor isvp_common.h CONFIG_SYS_APLL_MNOD values
	  (non-uniform, OD0 in the [7:5] field - do not recompute,
	  vendor-authoritative). T30A (APLL 1200 / DDR 600 / 128 MB
	  DDR2) is a future variant - not in this 64 MB choice.

config T30_VARIANT_T30L
	bool "T30L / lite (CPU 750 MHz, DDR 500, 64 MB)"

config T30_VARIANT_T30N
	bool "T30N (CPU 900 MHz, DDR 500, 64 MB)"

endchoice

config T30_VARIANT_NAME
	string
	default "T30N" if T30_VARIANT_T30N
	default "T30L"

config T30_APLL_MNOD
	hex
	default 0x04a04840 if T30_VARIANT_T30N
	default 0x07c05040
	help
	  CPAPCR value, exact vendor CONFIG_SYS_APLL_MNOD:
	  750 = (M=124,N=1,OD1=2<<11,OD0=2<<5) = 0x07c05040 (T30L);
	  900 = (M=74,N=1,OD1=1<<11,OD0=2<<5)  = 0x04a04840 (T30N).

config SPL_T30_USB_BOOT
	bool "T30 SPL: return to mask ROM for USB boot (dev loop)"
	depends on SPL
	help
	  Build the SPL as a mask-ROM USB-boot stage1: bring up the
	  clocks (and DDR once ported), then return to the bootrom
	  (jr ra) instead of loading U-Boot proper from SPI-NOR -
	  how the SPL is brought up and tested on the lab rig.
	  Development only.

endif

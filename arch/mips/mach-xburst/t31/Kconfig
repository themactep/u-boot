if SOC_T31

choice
	prompt "T31 SoC variant"
	default T31_VARIANT_T31X
	help
	  Specific T31 product variant. All share the MPLL/VPLL and the
	  Innophy PHY and differ in the APLL (CPU) clock and the DRAM
	  part: T31N/T31L/T31LC populate 64 MB DDR2 (M14D5121632A,
	  4-bank); T31X/T31AL populate 128 MB DDR2 (M14D1G1664A,
	  8-bank); T31A and C100 populate 128 MB DDR3 (M15T1G1664A,
	  8-bank, hardware write-leveling). Each is a distinct entry
	  so the exact SKU is identified at boot.

config T31_VARIANT_C100
	bool "C100 (DDR3-128M, CPU 1392 MHz)"

config T31_VARIANT_T31A
	bool "T31A (DDR3-128M, CPU 1512 MHz)"
	help
	  T31A populates 128 MB DDR3 M15T1G1664A and uses the legacy
	  Innophy DDR3 controller/PHY init path (DFI reset, the DDR3
	  LMR MRS sequence and hardware write-leveling) instead of the
	  DDR2 soft path. Selects CONFIG_T31_DDR3.

config T31_VARIANT_T31AL
	bool "T31AL (DDR2-128M, CPU 1392 MHz)"

config T31_VARIANT_T31L
	bool "T31L (DDR2-64M, CPU 1008 MHz, lite)"

config T31_VARIANT_T31LC
	bool "T31LC (DDR2-64M, CPU 1104 MHz, lite)"

config T31_VARIANT_T31N
	bool "T31N (DDR2-64M, CPU 1392 MHz)"
	help
	  Nominal 1400 MHz; the PLL aligns it to 1392 exactly as the
	  vendor get_pllreg_value() does.

config T31_VARIANT_T31X
	bool "T31X (DDR2-128M, CPU 1392 MHz)"

endchoice

config T31_VARIANT_NAME
	string
	default "C100"  if T31_VARIANT_C100
	default "T31A"  if T31_VARIANT_T31A
	default "T31AL" if T31_VARIANT_T31AL
	default "T31L"  if T31_VARIANT_T31L
	default "T31LC" if T31_VARIANT_T31LC
	default "T31N"  if T31_VARIANT_T31N
	default "T31X"  if T31_VARIANT_T31X

config T31_DRAM_128M
	bool
	default y if T31_VARIANT_T31X || T31_VARIANT_T31AL || \
		     T31_VARIANT_T31A || T31_VARIANT_C100
	help
	  T31X/T31AL populate the 128 MB DDR2 M14D1G1664A (8-bank);
	  T31A/C100 the 128 MB DDR3 M15T1G1664A (8-bank); T31N/T31L/
	  T31LC the 64 MB DDR2 M14D5121632A (4-bank). Selects the
	  matching DDRC_CFG/MMAP geometry, the 8-bank flag and the
	  chip size in mach/t31-ddr.h (the 128 MB DDR2 and DDR3 parts
	  share row/col/bank/size).

config T31_DDR3
	bool
	default y if T31_VARIANT_T31A || T31_VARIANT_C100
	help
	  T31A and C100 are DDR3 M15T1G1664A (128 MB). Selects the
	  DDR3 controller/PHY parameter set (mach/t31-ddr.h: DDRC_CFG
	  /REFCNT/TIMING1-6/MR0, the DDR3-@600 set from isvp_c100)
	  and the legacy Innophy DDR3 init branches in t31/sdram.c
	  (INNO_MEM_CFG=0x30, DFI reset, the no-poll DDR3 LMR MRS
	  sequence and hardware write-leveling) instead of the DDR2
	  soft path. Geometry is shared via T31_DRAM_128M. The DDR
	  clock is MPLL/2 (T31_MPLL_MHZ): T31A 750, C100 600. APLL
	  differs too (T31A 1512, C100 1392, via T31_APLL_MHZ).

config T31_APLL_MHZ
	int
	default 1512 if T31_VARIANT_T31A
	default 1416 if T31_VARIANT_T31N
	default 1008 if T31_VARIANT_T31L
	default 1104 if T31_VARIANT_T31LC
	default 1392
	help
	  APLL (CPU PLL) target in MHz for the selected variant.
	  These are the post-alignment values the vendor
	  get_pllreg_value() actually programs (it aligns the
	  nominal freq to a 24 MHz multiple): T31N nominal 1404 ->
	  1416 (M=118); T31A nominal 1500 -> 1512 (M=126); LC 1104;
	  L 1008; X/AL/C100 1392. The SPL programs CPAPCR
	  M = T31_APLL_MHZ / 12 (N=1, OD0=1, OD1=2); the value must
	  be a multiple of 12 and keep Fvco = 24*M in 1250-5000 MHz.

config T31_MPLL_MHZ
	int
	default 1512 if T31_VARIANT_T31A
	default 1008 if T31_VARIANT_T31N || T31_VARIANT_T31L || \
			T31_VARIANT_T31LC
	default 1200
	help
	  MPLL target in MHz (post-alignment, what vendor
	  get_pllreg_value() programs) for the selected variant.
	  MPLL feeds the DDR clock (DDR = MPLL/2) and the H0/H2/PCLK
	  bus tree:
	    1008 -> DDR 504 : T31N/T31L/T31LC (DDR2-64M; vendor
	            "1000" aligned to 1008, M=84)
	    1200 -> DDR 600 : T31X/T31AL (DDR2-128M), C100 (DDR3)
	    1512 -> DDR 756 : T31A (DDR3; vendor "1500" aligned to
	            1512, M=126 - DDR3 params are the nominal-750
	            set, exactly as the vendor runs them at 756)
	  The SPL programs CPMPCR M = T31_MPLL_MHZ / 12 (N=1, OD0=1,
	  OD1=2); must be a multiple of 12 (1008/1200/1512 -> M
	  84/100/126). The 1008 group uses the vendor DDR_500M CPCCR
	  bus dividers (PCLK 8 / H2 4 / H0 4); 1200/1512 share PCLK
	  12 / H2 6 / H0 6 (t31/pll.c picks per band).

config SPL_T31_USB_BOOT
	bool "T31 SPL: return to mask ROM for USB boot (dev loop)"
	depends on SPL
	help
	  Build the SPL as a mask-ROM USB-boot stage1: bring up the
	  clocks and DDR, then return to the bootrom (jr ra) instead of
	  loading U-Boot proper from SPI-NOR. The host then uploads
	  U-Boot straight into DRAM over USB (VR_PROGRAM_START2), so a
	  build can be booted without touching the NOR flash. For
	  development only; the production image uses the SFC-NOR SPL.

config SYS_SOC
	default "t31"

config SYS_DCACHE_SIZE
	default 32768

config SYS_ICACHE_SIZE
	default 32768

config SYS_DCACHE_LINE_SIZE
	default 32

config SYS_ICACHE_LINE_SIZE
	default 32

endif

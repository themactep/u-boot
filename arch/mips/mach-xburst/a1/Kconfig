if SOC_A1

# A1 SoC variant, DDR parameters, DRAM size and PLL setpoints are all
# selected at runtime from the device tree (the per-SKU <sku>-isvp.dts sets
# ingenic,variant on the memory-controller node; the UCLASS_RAM driver and
# pll_init() read it). No compile-time variant Kconfig is needed.

config SPL_A1_USB_BOOT
	bool "A1 SPL: return to mask ROM for USB boot (dev loop)"
	depends on SPL
	help
	  Build the SPL as a mask-ROM USB-boot stage1: bring up the
	  PLLs and DDR, then return to the bootrom (jr ra) instead of
	  loading U-Boot proper from SPI-NOR. The mask ROM then uploads
	  U-Boot proper over USB. Used by the USB-boot / DFU loader
	  defconfig (isvp_a1_usbboot_defconfig). Development only.

endif

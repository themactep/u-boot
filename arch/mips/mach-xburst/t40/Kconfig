if SOC_T40

choice
	prompt "T40 SoC variant"
	default T40_VARIANT_T40N
	help
	  T40 product variant. DDR parameters are taken from the
	  vendor U-Boot ddr_params_creator host-tool output. Default
	  variant is T40N (DDR2 128 MiB M14D5121632A in 32-bit config)
	  which is the variant in the IPC camera modules we have on
	  the bench.

config T40_VARIANT_T40N
	bool "T40N (DDR2-500, 128 MiB)"
	help
	  T40N: DDR2 @ 500 MHz, 32-bit bus, 128 MiB
	  M14D5121632A. APLL 912 MHz, MPLL 1000 MHz, per vendor
	  include/configs/isvp_t40.h DDR_500M / APLL_912M block.

endchoice

config T40_DRAM_SIZE_MB
	int
	default 128 if T40_VARIANT_T40N

config SPL_T40_USB_BOOT
	bool "T40 SPL: return to mask ROM for USB boot (dev loop)"
	depends on SPL
	help
	  Build the SPL as a mask-ROM USB-boot stage1: bring up the
	  PLLs and DDR, then return to the bootrom (jr ra) instead of
	  loading U-Boot proper from SPI-NOR. The mask ROM then uploads
	  U-Boot proper over USB. Used by the USB-boot / DFU loader
	  defconfig (isvp_t40_usbboot_defconfig).

endif

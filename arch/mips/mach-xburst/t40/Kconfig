if SOC_T40

choice
	prompt "T40 SoC variant"
	default T40_VARIANT_T40N
	help
	  T40 product variant. DDR parameters per variant come from
	  the vendor U-Boot ddr_params_creator host-tool output for
	  the specific chip + freq + bus config. Set per board /
	  defconfig.

config T40_VARIANT_T40N
	bool "T40N (DDR2-500, 128 MiB, 32-bit)"
	help
	  T40N: DDR2 @ 500 MHz, 32-bit bus, 128 MiB M14D5121632A.
	  APLL 912 MHz, MPLL 1000 MHz, per vendor
	  include/configs/isvp_t40.h DDR_500M / APLL_912M block.

config T40_VARIANT_T40XP
	bool "T40XP (DDR3-1333, 256 MiB, 32-bit)"
	help
	  T40XP: DDR3 @ 600 MHz, 32-bit bus, 256 MiB M15T1G1664A_2C.
	  APLL 1008 MHz, MPLL 1200 MHz, per vendor
	  include/configs/isvp_t40.h DDR_600M / APLL_1008M block.

endchoice

config T40_DRAM_SIZE_MB
	int
	default 128 if T40_VARIANT_T40N
	default 256 if T40_VARIANT_T40XP

config SPL_T40_USB_BOOT
	bool "T40 SPL: return to mask ROM for USB boot (dev loop)"
	depends on SPL
	help
	  Build the SPL as a mask-ROM USB-boot stage1: bring up the
	  PLLs and DDR, then return to the bootrom (jr ra) instead of
	  loading U-Boot proper from SPI-NOR. The mask ROM then uploads
	  U-Boot proper over USB. Used by the USB-boot / DFU loader
	  defconfigs (isvp_t40n_usbboot_defconfig,
	  isvp_t40xp_usbboot_defconfig).

config SPL_T40_NOR_PROBE
	bool "T40 SPL: ASM-only NOR-boot probe (spins emitting 'A')"
	depends on SPL && !SPL_T40_USB_BOOT
	help
	  Diagnostic SPL that bypasses board_init_f and instead does the
	  bare minimum (WDT disable, UART1 clock ungate, PB23/24 to FUNC0,
	  UART setup, spin emitting 'A') to bisect where the C SPL goes
	  silent on cold SFC NOR boot. Enable only for short-cycle bring-up
	  testing of the NOR boot path.

config SPL_T40_NAND_PROBE_BOOT
	bool "T40 SPL: ASM-only NAND-boot probe (spins emitting 'A')"
	depends on SPL && !SPL_T40_USB_BOOT && !SPL_T40_NOR_PROBE
	help
	  Diagnostic SPL that uses the SPI-NAND boot header (byte 8 = 0x00)
	  but the same minimal asm payload as SPL_T40_NOR_PROBE (WDT disable,
	  UART1 clock ungate, PB23/24 to FUNC0, UART setup, spin emitting 'A').
	  Lets us bisect whether the mask ROM is loading our SPL bytes from
	  NAND at all on cold-boot: if 'A' appears, bootrom loads + jumps
	  correctly and the production SPL has a NAND-specific runtime bug;
	  if silent, bootrom rejects/ignores the NAND image regardless of
	  payload.

config SPL_T40_SFC_NAND_BOOT
	bool "T40 SPL: load U-Boot proper from SPI-NAND via SFC"
	depends on SPL && !SPL_T40_USB_BOOT && !SPL_T40_NOR_PROBE && !SPL_T40_NAND_PROBE_BOOT
	help
	  Build the SPL as a cold-boot stage1 that probes the SPI-NAND
	  on SFC, reads U-Boot proper out of the NAND at a fixed offset
	  (T40_NAND_UBOOT_OFFSET, default 128 KiB), and jumps. Used by
	  the production T40XP SFCNAND defconfig
	  (isvp_t40xp_sfcnand_defconfig). The driver lives in
	  arch/mips/mach-xburst/t40/sfc_nand.c.

config SPL_T40_NAND_PROBE
	bool "T40 SPL: probe SPI-NAND and print chip ID (USB-boot debug)"
	depends on SPL && SPL_T40_USB_BOOT
	help
	  Diagnostic: link the SFC SPI-NAND probe into the USB-boot SPL
	  and call sfc_nand_init() just before returning to mask ROM.
	  Lets us validate the NAND read path on real silicon without
	  having to commit a flash layout for U-Boot in NAND first. The
	  SPL still returns to mask ROM after the probe, so U-Boot is
	  uploaded over USB exactly as in the plain USB-boot defconfig.

endif

if SOC_T40

choice
	prompt "T40 SoC variant"
	default T40_VARIANT_T40NN
	help
	  T40 product variant. The four T40 SKUs per vendor
	  include/configs/isvp_common.h:
	    T40A  - DDR3 32-bit dual-rank 1 GiB (M15T4G16256A_2S)
	    T40N  - DDR2 32-bit       128 MiB (M14D5121632A)
	    T40NN - DDR2 32-bit       128 MiB (M14D5121632A, cloner setpoint)
	    T40XP - DDR3 32-bit       256 MiB (M15T1G1664A_2C)
	  DDR parameters per variant come from the vendor U-Boot
	  `tools/ingenic-tools/ddr_params_creator` host-tool output for
	  the specific chip + freq + bus configuration. Vendor does not
	  ship a separate T40NN target - mainline keeps T40NN distinct
	  to preserve the cloner-derived 500 MHz DDR2 timings that the
	  lab T40 board (silkscreen "T40NN") boots cleanly on.

config T40_VARIANT_T40A
	bool "T40A (DDR3-1333, 1 GiB dual-rank, 32-bit) [untested]"
	help
	  T40A: DDR3 32-bit dual-rank M15T4G16256A_2S (1 GiB total per
	  ddr_params_creator; vendor isvp_common.h tags as
	  CONFIG_DDR_128M for SoC addressing). APLL 1008 MHz, MPLL 1400
	  MHz (DDR=700 MHz). Values are direct ddr_params_creator output
	  from isvp_t40a_sfcnor; not yet validated in mainline (no T40A
	  hardware in the lab).

config T40_VARIANT_T40N
	bool "T40N (DDR2-1100, 128 MiB, 32-bit) [untested]"
	help
	  T40N: DDR2 32-bit 128 MiB M14D5121632A. APLL 912 MHz, MPLL
	  1100 MHz (DDR=550 MHz), per vendor isvp_common.h CONFIG_T40N /
	  DDR_550M block. Values are direct ddr_params_creator output
	  from isvp_t40n_sfcnor; not yet validated in mainline at the
	  vendor 550 MHz target. For the conservative 500 MHz cloner
	  timings that the lab T40 board boots on, select T40NN.

config T40_VARIANT_T40NN
	bool "T40NN (DDR2-1000, 128 MiB, 32-bit) [HW-validated]"
	help
	  T40NN: DDR2 32-bit 128 MiB M14D5121632A. APLL 912 MHz, MPLL
	  1000 MHz (DDR=500 MHz), cloner-derived from
	  thingino-cloner/firmwares/t40. The conservative setpoint vs
	  the vendor T40N 550 MHz; the cloner underclocks for margin and
	  this is the setpoint that boots cleanly on the lab T40 board
	  (silkscreen "T40NN"). HW-validated. Vendor isvp_common.h has
	  no separate T40NN target - it groups this silicon under
	  CONFIG_T40N at the higher vendor 550 MHz clock.

config T40_VARIANT_T40XP
	bool "T40XP (DDR3-1200, 256 MiB, 32-bit) [HW-validated]"
	help
	  T40XP: DDR3 32-bit 256 MiB M15T1G1664A_2C. APLL 1008 MHz,
	  MPLL 1200 MHz (DDR=600 MHz). Cloner-derived (vendor
	  isvp_common.h CONFIG_T40XP block targets MPLL 1400 MHz / DDR
	  700 MHz; mainline runs the conservative cloner value until the
	  vendor 700 MHz timings are validated). HW-validated.

endchoice

config T40_DRAM_SIZE_MB
	int
	default 128 if T40_VARIANT_T40A
	default 128 if T40_VARIANT_T40N
	default 128 if T40_VARIANT_T40NN
	default 256 if T40_VARIANT_T40XP

config SPL_T40_USB_BOOT
	bool "T40 SPL: return to mask ROM for USB boot (dev loop)"
	depends on SPL
	help
	  Build the SPL as a mask-ROM USB-boot stage1: bring up the
	  PLLs and DDR, then return to the bootrom (jr ra) instead of
	  loading U-Boot proper from SPI-NOR. The mask ROM then uploads
	  U-Boot proper over USB. Used by the USB-boot / DFU loader
	  defconfigs (isvp_t40n_usbboot_defconfig,
	  isvp_t40xp_usbboot_defconfig).

config SPL_T40_SFC_NAND_BOOT
	bool "T40 SPL: load U-Boot proper from SPI-NAND via SFC"
	depends on SPL && !SPL_T40_USB_BOOT
	help
	  Build the SPL as a cold-boot stage1 that probes the SPI-NAND
	  on SFC, reads U-Boot proper out of the NAND at a fixed offset
	  (T40_NAND_UBOOT_OFFSET, default 128 KiB), and jumps. Used by
	  the production T40XP SFCNAND defconfig
	  (isvp_t40xp_sfcnand_defconfig). The driver lives in
	  arch/mips/mach-xburst/t40/sfc_nand.c.

config SPL_T40_NAND_PROBE
	bool "T40 SPL: probe SPI-NAND and print chip ID (USB-boot debug)"
	depends on SPL && SPL_T40_USB_BOOT
	help
	  Diagnostic: link the SFC SPI-NAND probe into the USB-boot SPL
	  and call sfc_nand_init() just before returning to mask ROM.
	  Lets us validate the NAND read path on real silicon without
	  having to commit a flash layout for U-Boot in NAND first. The
	  SPL still returns to mask ROM after the probe, so U-Boot is
	  uploaded over USB exactly as in the plain USB-boot defconfig.

endif

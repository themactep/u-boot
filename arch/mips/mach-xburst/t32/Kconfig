if SOC_T32

# The T32 SKU (DDR type/geometry, uMCTL2/PHY tables, clock setpoints)
# is selected at runtime from the devicetree: the DDR node's compatible
# picks the per-variant table in drivers/ram/ingenic/ddr_t32.c
# (of_match .data). There is no compile-time T32 variant Kconfig.
# SYS_MIPS_TIMER_FREQ (the CP0 timer = CPU/APLL clock) is set as a
# literal per defconfig, matching the SKU's leaf devicetree.

config SPL_T32_USB_BOOT
	bool "T32 SPL: return to mask ROM for USB boot (dev loop)"
	depends on SPL
	help
	  Build the SPL as a mask-ROM USB-boot stage1: bring up the
	  clocks and DDR, then return to the bootrom (jr ra) instead of
	  loading U-Boot proper from SPI-NOR. The host then uploads
	  U-Boot straight into DRAM over USB, so a build can be booted
	  without touching the NOR flash. For development only; the
	  production image uses the SFC-NOR SPL.

endif

// SPDX-License-Identifier: GPL-2.0+

#include <dt-bindings/clock/ingenic,t31-cgu.h>

/ {
	#address-cells = <1>;
	#size-cells = <1>;
	compatible = "ingenic,t31";

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "ingenic,xburst", "mips,mips32r2";
			reg = <0>;
		};
	};

	cpuintc: interrupt-controller {
		#address-cells = <0>;
		#interrupt-cells = <1>;
		interrupt-controller;
		compatible = "mti,cpu-interrupt-controller";
	};

	exclk: exclk {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <24000000>;
	};

	rtclk: rtclk {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <32768>;
	};

	/*
	 * CGU (Clock/Power Manager). The SPL programs the PLLs and the
	 * CPU/DDR/bus dividers; this driver runs in U-Boot proper and
	 * recalculates the PLL rates and provides rate/gate control for
	 * the leaf peripheral clocks (SFC, MMC, GMAC). Binding mirrors
	 * the mainline Linux port (ingenic,t31-cgu) so one device tree is
	 * valid on both. The driver accesses the CPM block via KSEG1.
	 */
	cgu: clock-controller@10000000 {
		compatible = "ingenic,t31-cgu", "simple-mfd";
		reg = <0x10000000 0x1000>;
		#clock-cells = <1>;
		clocks = <&exclk>, <&rtclk>;
		clock-names = "ext", "rtc";
		u-boot,dm-pre-reloc;
	};

	/*
	 * DDR2/DDR3 controller + Innophy PHY. The per-SKU compatible
	 * (ingenic,t31<sku>-ddr-innophy) is set by the leaf .dts and
	 * selects the variant table in drivers/ram/ingenic/ddr_t31.c
	 * (of_match .data). bootph-all is added by the leaf's shared
	 * U-Boot overlay so the node survives into the SPL devicetree.
	 */
	ddr: memory-controller@134f0000 {
		reg = <0x134f0000 0x1000>;
	};

	/*
	 * TCU (timer/counter unit). Container node mirroring the mainline
	 * Linux binding (ingenic,t31-tcu / simple-mfd) so the watchdog
	 * child binds; U-Boot only needs the watchdog (for sysreset).
	 * The watchdog driver self-clocks from the 32 kHz RTC, so the
	 * TCU clock provider is not required here.
	 */
	tcu: timer@10002000 {
		compatible = "ingenic,t31-tcu", "ingenic,jz4760-tcu",
			     "simple-mfd";
		reg = <0x10002000 0x1000>;
		#address-cells = <1>;
		#size-cells = <1>;
		ranges = <0x0 0x10002000 0x1000>;

		watchdog: watchdog@0 {
			compatible = "ingenic,t31-watchdog",
				     "ingenic,jz4780-watchdog";
			reg = <0x0 0x10>;
		};
	};

	uart1: serial@10031000 {
		compatible = "ingenic,jz4780-uart";
		reg = <0x10031000 0x100>;
		reg-shift = <2>;
		clock-frequency = <24000000>;
		status = "disabled";
	};

	sfc: spi@13440000 {
		compatible = "ingenic,t31-sfc";
		reg = <0x13440000 0x10000>;
		#address-cells = <1>;
		#size-cells = <0>;
		clocks = <&cgu T31_CLK_SFC>;
		spi-max-frequency = <50000000>;
		pinctrl-names = "default";
		pinctrl-0 = <&pins_sfc>;
		status = "disabled";
	};

	msc0: mmc@13450000 {
		compatible = "ingenic,t31-mmc";
		reg = <0x13450000 0x1000>;
		clocks = <&cgu T31_CLK_MSC0>;
		clock-names = "mmc";
		cap-sd-highspeed;
		pinctrl-names = "default";
		pinctrl-0 = <&pins_mmc0>;
		status = "disabled";
	};

	/*
	 * Pin controller + GPIO. Mirrors the mainline Linux
	 * ingenic,t31-pinctrl binding: the pin-controller owns the
	 * register block and has four ingenic,t31-gpio child banks
	 * (PA..PD). Consumers select a function via the standard pinmux
	 * binding (pinctrl-0 -> a node with function/groups).
	 */
	pinctrl: pinctrl@10010000 {
		compatible = "ingenic,t31-pinctrl";
		reg = <0x10010000 0x1000>;
		#address-cells = <1>;
		#size-cells = <0>;

		gpa: gpio@0 {
			compatible = "ingenic,t31-gpio";
			reg = <0>;
			gpio-controller;
			#gpio-cells = <2>;
		};

		gpb: gpio@1 {
			compatible = "ingenic,t31-gpio";
			reg = <1>;
			gpio-controller;
			#gpio-cells = <2>;
		};

		gpc: gpio@2 {
			compatible = "ingenic,t31-gpio";
			reg = <2>;
			gpio-controller;
			#gpio-cells = <2>;
		};

		gpd: gpio@3 {
			compatible = "ingenic,t31-gpio";
			reg = <3>;
			gpio-controller;
			#gpio-cells = <2>;
		};

		pins_sfc: sfc {
			function = "sfc";
			groups = "sfc-data";
		};

		pins_mmc0: mmc0 {
			function = "mmc0";
			groups = "mmc0-1bit", "mmc0-4bit";
		};

		pins_mac: mac {
			function = "mac";
			groups = "mac-rmii";
		};
	};

	/*
	 * GMAC: Synopsys DesignWare MAC. ingenic,mode-reg is the CPM
	 * GMAC-PHY-control register (CPM 0xb0000000 + 0xe8) used to
	 * select the PHY interface and speed; the glue also ungates the
	 * GMAC clock and programs CPM_MACCDR for the MAC-PHY rate.
	 */
	gmac: ethernet@134b0000 {
		compatible = "ingenic,t31-gmac";
		reg = <0x134b0000 0x2000>;
		phy-mode = "rmii";
		max-speed = <100>;
		macphy-rate = <50000000>;
		clocks = <&cgu T31_CLK_GMAC>;
		ingenic,mode-reg = <0x100000e8>;
		pinctrl-names = "default";
		pinctrl-0 = <&pins_mac>;
		status = "disabled";
	};

	/*
	 * DWC2 USB OTG. One controller, one DM bind: host (usb start ->
	 * USB ethernet/storage) OR gadget (dfu/ums) - not both at once.
	 * Production default is host so USB networking works out of the
	 * box; entering DFU for field firmware update is a deliberate
	 * role switch on a recovery trigger (TODO, see memory). The
	 * USB-boot dev loop uses a separate gadget build for flashing.
	 */
	otg: usb@13500000 {
		compatible = "snps,dwc2";
		reg = <0x13500000 0x40000>;
		dr_mode = "host";
		clocks = <&cgu T31_CLK_OTG>;
		g-rx-fifo-size = <512>;
		g-np-tx-fifo-size = <16>;
		g-tx-fifo-size = <256 256 16 16 16>;
		status = "disabled";
	};

	/*
	 * Audio: AIC (I2S) controller + on-chip codec. PIO playback driven
	 * by U-Boot's `sound` command. Speaker-amp enable GPIO is per-board
	 * (set in the board .dts via ingenic,spk-gpio; SDK default PB31
	 * active-high). Compatible split: T20 -> A-block codec; T31/C100/T23
	 * -> B-block codec (jz_t10_codec handles both via driver_data).
	 */
	aic: audio-controller@10020000 {
		compatible = "ingenic,t31-aic";
		reg = <0x10020000 0x100>;
		#sound-dai-cells = <0>;
		status = "disabled";
	};

	codec: audio-codec@10021000 {
		compatible = "ingenic,t31-codec";
		reg = <0x10021000 0x140>;
		#sound-dai-cells = <0>;
		status = "disabled";
	};

	sound: sound {
		compatible = "ingenic,t31-sound";
		status = "disabled";

		cpu {
			sound-dai = <&aic>;
		};

		codec {
			sound-dai = <&codec>;
		};
	};
};

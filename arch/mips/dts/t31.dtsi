#include <dt-bindings/clock/t31-cgu.h>

/ {
	#address-cells = <1>;
	#size-cells = <1>;
	compatible = "ingenic,t31";

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "ingenic,xburst", "mips,mips32r2";
			reg = <0>;
		};
	};

	cpuintc: interrupt-controller {
		#address-cells = <0>;
		#interrupt-cells = <1>;
		interrupt-controller;
		compatible = "mti,cpu-interrupt-controller";
	};

	ext: ext {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <24000000>;
	};

	/*
	 * CGU (Clock/Power Manager). The SPL programs the PLLs and the
	 * CPU/DDR/bus dividers; this driver runs in U-Boot proper and
	 * recalculates the PLL rates and provides rate/gate control for
	 * the leaf peripheral clocks (SFC, MMC, GMAC). reg is the CPM
	 * block; the driver accesses it through the KSEG1 window.
	 */
	cgu: clock-controller@10000000 {
		compatible = "ingenic,t31-cgu";
		reg = <0x10000000 0x1000>;
		#clock-cells = <1>;
		clocks = <&ext>;
		u-boot,dm-pre-reloc;
	};

	uart1: serial@10031000 {
		compatible = "ingenic,jz4780-uart";
		reg = <0x10031000 0x100>;
		reg-shift = <2>;
		clock-frequency = <24000000>;
		status = "disabled";
	};

	sfc: spi@13440000 {
		compatible = "ingenic,t31-sfc";
		reg = <0x13440000 0x10000>;
		#address-cells = <1>;
		#size-cells = <0>;
		clocks = <&cgu T31_CLK_SFC>;
		spi-max-frequency = <50000000>;
		status = "disabled";
	};

	msc0: mmc@13450000 {
		compatible = "ingenic,t31-mmc";
		reg = <0x13450000 0x1000>;
		clocks = <&cgu T31_CLK_MSC0>;
		clock-names = "mmc";
		cap-sd-highspeed;
		status = "disabled";
	};

	/*
	 * GPIO ports PA..PD. Always available (no board gating) so the
	 * gpio command can drive board-specific pins - e.g. an SD/MMC
	 * power-enable that varies per device and is not hardcoded.
	 */
	gpa: gpio@10010000 {
		compatible = "ingenic,t31-gpio";
		reg = <0x10010000 0x1000>;
		gpio-controller;
		#gpio-cells = <2>;
		gpio-bank-name = "PA";
		ngpios = <32>;
	};

	gpb: gpio@10011000 {
		compatible = "ingenic,t31-gpio";
		reg = <0x10011000 0x1000>;
		gpio-controller;
		#gpio-cells = <2>;
		gpio-bank-name = "PB";
		ngpios = <32>;
	};

	gpc: gpio@10012000 {
		compatible = "ingenic,t31-gpio";
		reg = <0x10012000 0x1000>;
		gpio-controller;
		#gpio-cells = <2>;
		gpio-bank-name = "PC";
		ngpios = <32>;
	};

	gpd: gpio@10013000 {
		compatible = "ingenic,t31-gpio";
		reg = <0x10013000 0x1000>;
		gpio-controller;
		#gpio-cells = <2>;
		gpio-bank-name = "PD";
		ngpios = <32>;
	};

	/*
	 * GMAC: Synopsys DesignWare MAC. ingenic,mode-reg is the CPM
	 * GMAC-PHY-control register (CPM 0xb0000000 + 0xe8) used to
	 * select the PHY interface and speed; the glue also ungates the
	 * GMAC clock and programs CPM_MACCDR for the MAC-PHY rate.
	 */
	gmac: ethernet@134b0000 {
		compatible = "ingenic,t31-gmac";
		reg = <0x134b0000 0x2000>;
		phy-mode = "rmii";
		max-speed = <100>;
		macphy-rate = <50000000>;
		clocks = <&cgu T31_CLK_MAC>;
		ingenic,mode-reg = <0x100000e8>;
		status = "disabled";
	};

	/*
	 * DWC2 USB OTG. board_init() brings up the PHY/clock. The same
	 * node serves both the host driver (usb start -> USB ethernet,
	 * storage) and the gadget driver (dfu / ums for flashing).
	 */
	otg: usb@13500000 {
		compatible = "snps,dwc2";
		reg = <0x13500000 0x40000>;
		dr_mode = "otg";
		clocks = <&cgu T31_CLK_OTG>;
		g-rx-fifo-size = <512>;
		g-np-tx-fifo-size = <16>;
		g-tx-fifo-size = <256 256 16 16 16>;
		status = "disabled";
	};
};

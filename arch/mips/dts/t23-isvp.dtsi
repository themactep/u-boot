/*
 * Ingenic ISVP-T23 shared board body (SFC-NOR, USB host).
 *
 * The per-SKU leaf .dts files (t23n-isvp.dts, ...) include this and
 * supply the DDR node's per-SKU "ingenic,sdram-params" array, consumed
 * by the shared Innophy DDR driver (ddr_t31.c). The matching
 * <leaf>-u-boot.dtsi pulls in t23-isvp-uboot-common.dtsi
 * (binman image + SPL bootph).
 */

#include <dt-bindings/gpio/gpio.h>
#include "t23.dtsi"

/ {
	compatible = "ingenic,isvp-t23", "ingenic,t23";
	model = "Ingenic ISVP-T23 (SFC NOR)";

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory {
		device_type = "memory";
		/* Placeholder; the DDR driver reports the real per-SKU size. */
		reg = <0x0 0x04000000>;
	};
};

&uart1 {
	status = "okay";
};

&sfc {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

&msc0 {
	status = "okay";
	bus-width = <4>;
	broken-cd;	/* no card-detect line wired on the ISVP board */
};

&gmac {
	status = "okay";
	/* PHY reset GPIO; exact pin varies per board, override per device. */
	ingenic,reset-gpio = <&gpb 28 GPIO_ACTIVE_LOW>;
};

&otg {
	status = "okay";
};

&aic {
	status = "okay";
};

&codec {
	status = "okay";
	/* Speaker-amp enable: SDK default PB31, active-high. Override
	 * here per board if the amp is on a different pin/polarity. */
	ingenic,spk-gpio = <&gpb 31 GPIO_ACTIVE_HIGH>;
};

&sound {
	status = "okay";
};

/*
 * Ingenic ISVP-T10, DFU/USB-boot loader variant.
 *
 * Identical to t10-isvp.dts except the DWC2 OTG is dr_mode =
 * "peripheral" so the dwc2_udc_otg gadget binds (dwc2_udc_otg_bind
 * rejects "host"). Used only by isvp_t10_usbboot_defconfig - the
 * dev/flash loader that USB-boots and auto-enters DFU. Production
 * NOR uses t10-isvp.dts (dr_mode="host" for USB host + USB-NIC).
 */

/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include "t10.dtsi"

/ {
	compatible = "ingenic,isvp-t10", "ingenic,t10";
	model = "Ingenic ISVP-T10 (DFU loader)";

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory {
		device_type = "memory";
		reg = <0x0 0x04000000>;	/* 64 MB DDR2 (T10N) */
	};
};

&uart1 {
	status = "okay";
};

&sfc {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

&msc0 {
	status = "okay";
	bus-width = <4>;
	broken-cd;
};

&otg {
	status = "okay";
	dr_mode = "peripheral";		/* gadget bind for DFU/g_dnl */
};

&ddr {
	/* T10N: DDR2 64 MB M14D5121632A (4-bank), CPU 860 / DDR 400 MHz. */
	ingenic,sdram-params = <
		0x04708900 0x06405100 0x9a0b5510	/* APLL860 MPLL1200 CPCCR */
		0x04000000				/* 64 MB */
		0x0a688a40 0x000020fc 0x00002400	/* CFG MMAP0 MMAP1 */
		0x040d0606 0x02120607 0x20060418	/* TIMING1..3 */
		0x14240031 0xff060505 0x32120505	/* TIMING4..6 */
		0x00000002 0x3092667a 0x002a0090	/* DCR DTPR0 DTPR1 */
		0x03020d0c 0x07060504 0x0b0a0908	/* REMAP1..3 */
		0x0f0e0100 0x13121110			/* REMAP4..5 */
		2					/* cdr (DDR = MPLL/3 = 400) */
		0x00c20001				/* REFCNT */
		0x00000a73 0x00220014 0x05013880	/* MR0 PTR0 PTR1 */
	>;
};

// SPDX-License-Identifier: GPL-2.0+
/*
 * Binman image description for the Ingenic ISVP-T31 DFU loader (USB-boot; binman image unused).
 *
 * The USB-boot path uploads spl/u-boot-spl.bin + u-boot-lzma.img
 * directly via the mask ROM (t31-usbboot.py), so the binman flash
 * images here are not used in the USB-boot flow. They are kept
 * consistent with the production t31-isvp layout (LZMA U-Boot at
 * 0x8000, not 0x10000) so a stray `make` of this config still
 * produces a sensible flash image. Outputs:
 *
 *   u-boot-spl-t31.bin : SPL with the finalized SFC-NOR boot header.
 *   u-boot-with-spl-lzma.bin : headered SPL at offset 0 and
 *                              LZMA U-Boot at the SPL-loader
 *                              offset (no 0xff padding).
 */

/ {
	binman: binman {
		multiple-images;
	};
};

&binman {
	u-boot-spl-t31 {
		filename = "u-boot-spl-t31.bin";

		ingenic-t31-spl {
			filename = "spl/u-boot-spl.bin";
			/* T31 mask ROM rejects images with INGE magic at
			 * 0x100; suppress so the unused-by-USB-boot binman
			 * image still matches the cold-boot layout. */
			ingenic,no-inge;
		};
	};

	flash {
		filename = "u-boot-with-spl-lzma.bin";
		pad-byte = <0xff>;

		spl {
			type = "blob";
			offset = <0x0>;
			filename = "u-boot-spl-t31.bin";
		};

		u-boot {
			type = "blob";
			offset = <0x8000>;
			filename = "u-boot-lzma.img";
		};
	};
};

/*
 * Ingenic ISVP-T31L DFU/USB-boot loader (DDR2 64 MB, CPU 1008 MHz).
 *
 * The T31L DDR2-64M init brings up the low 64 MB of any DDR2 T31 part,
 * so this loader doubles as the universal DDR2 DFU loader (T31N/L/LC/X/
 * AL). DDR3 parts (T31A) need their own loader.
 */

/dts-v1/;

#include "t31-isvp-dfu.dtsi"

/ {
	model = "Ingenic ISVP-T31L (DFU loader)";
};

&ddr {
	compatible = "ingenic,t31l-ddr-innophy";
};

/*
 * flash@0 declared spi-nand so the NAND stack binds on NAND boards.
 * board_late_init() (arch/mips/mach-xburst/dfu.c) auto-detects NOR vs
 * NAND: on a NOR board the spi-nand probe fails, the node is unbound,
 * and a SPI-NOR is probed on CS0 instead - one loader flashes either.
 */
&sfc {
	flash@0 {
		compatible = "spi-nand";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include "t20.dtsi"

/ {
	compatible = "ingenic,isvp-t20", "ingenic,t20";
	/* One DT serves T20N/T20L (64M) and T20X (128M); the real
	 * DRAM size is reported by dram_init, the SKU by checkboard. */
	model = "Ingenic ISVP-T20 (SFC NOR)";

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory {
		device_type = "memory";
		reg = <0x0 0x04000000>;	/* 64 MB DDR2 (T20N) */
	};
};

&uart1 {
	status = "okay";
};

&sfc {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

&msc0 {
	status = "okay";
	bus-width = <4>;
	broken-cd;	/* no card-detect line wired on the ISVP board */
};

&otg {
	status = "okay";
};

&aic {
	status = "okay";
};

&codec {
	status = "okay";
	ingenic,spk-gpio = <&gpb 31 GPIO_ACTIVE_HIGH>;
};

&sound {
	status = "okay";
};

/dts-v1/;
#include "t40-isvp.dtsi"
#include "t40-isvp-nand.dtsi"

/ {
	model = "Ingenic ISVP-T40XP (SFC NAND)";
};

/* T40XP: DDR3 M15T1G1664A_2C, 256 MiB, SFC-NAND. */
&ddr {
	ingenic,sdram-params = <
		0x00000000 0x00000001	/* type family */
		0x00000020 0x10000000 0x00000000	/* bus_width chip0_size chip1_size */
		0x47868c00 0x23c34600	/* mpll_hz ddr_hz */
		0x05405100 0x06405100 0x00000000	/* apll mpll vpll _mnod */
		0x2a002a35 0x0000b092 0x00000002 0x000020f0 0x00003000 0x62910083	/* cfg ctrl dlmr mmap0 mmap1 refcnt */
		0x07110a08 0x0809050b 0x03090409 0x1c201705 0x80057054	/* timing1..5 */
		0x21001249 0x00000000 0x00000001 0x00000001	/* autosr_cnt autosr_en hregpro pregpro */
		0x11111111 0x00000113	/* cguc0 cguc1 */
		0x00000010 0x0000000b 0x00000009	/* memcfg cl cwl */
		0x00001b70 0x00010042 0x00020018 0x00030000 0x00000000 0x00000000	/* mr0 mr1 mr2 mr3 mr10 mr63 */
		0x030f0e0d 0x07060504 0x0b0a0908 0x0201000c 0x13121110	/* remap1..5 */
		0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000 0x00000000	/* par[19] (efuse drive/ODT/skew; 0 on T40) */
	>;
};

/*
 * Ingenic ISVP-T32 shared board body (SFC-NOR, USB host).
 *
 * The per-SKU leaf .dts files (t32lq-isvp.dts, ...) include this and
 * set the DDR node's per-SKU compatible (ingenic,t32<sku>-ddr-innophy),
 * which selects the variant table in the DDR driver. The matching
 * <leaf>-u-boot.dtsi pulls in t32-isvp-uboot-common.dtsi (binman image
 * + SPL bootph).
 */

#include <dt-bindings/gpio/gpio.h>
#include "t32.dtsi"

/ {
	compatible = "ingenic,isvp-t32", "ingenic,t32";
	model = "Ingenic ISVP-T32 (SFC NOR)";

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory {
		device_type = "memory";
		/* Placeholder; the DDR driver reports the real per-SKU size. */
		reg = <0x0 0x04000000>;
	};
};

&uart1 {
	status = "okay";
};

&sfc {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

&msc0 {
	status = "okay";
};

&gmac {
	status = "okay";
	/* No PHY reset line by default (the driver falls back to an MDIO
	 * BMCR soft-reset). Boards that wire one add ingenic,reset-gpio
	 * here, like T31 (vendor T32 reference: PB26 active-low). */
};

&otg {
	status = "okay";
	/* Host by default; USB-NIC and mass-storage commands need a
	 * host controller. Switch to "peripheral" via the dedicated
	 * isvp_t32_usbboot defconfig + DT pair for DFU loads. */
	dr_mode = "host";
};

&aic {
	status = "okay";
};

&codec {
	status = "okay";
	ingenic,spk-gpio = <&gpb 31 GPIO_ACTIVE_LOW>;
};

&sound {
	status = "okay";
};

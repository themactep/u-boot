/*
 * Ingenic ISVP-T21 shared DFU/USB-boot board body.
 *
 * Identical to t21-isvp.dtsi except the DWC2 OTG is dr_mode =
 * "peripheral" so the dwc2_udc_otg gadget binds (dwc2_udc_otg_bind
 * rejects "host"), and the audio nodes stay off. Used by the usbboot
 * defconfig - the dev/flash loader that USB-boots and auto-enters
 * DFU. Production NOR uses t21-isvp.dtsi (dr_mode="host" for USB
 * host + USB-NIC).
 *
 * The per-SKU leaf .dts files (t21n-isvp-dfu.dts, ...) include this
 * and supply the DDR node's per-SKU "ingenic,sdram-params" array; the matching
 * <leaf>-u-boot.dtsi pulls in t21-isvp-dfu-uboot-common.dtsi.
 */

#include <dt-bindings/gpio/gpio.h>
#include "t21.dtsi"

/ {
	compatible = "ingenic,isvp-t21", "ingenic,t21";
	model = "Ingenic ISVP-T21 (DFU loader)";

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory {
		device_type = "memory";
		reg = <0x0 0x04000000>;	/* 64 MB DDR2 (T21N) */
	};
};

&uart1 {
	status = "okay";
};

&sfc {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

&msc0 {
	status = "okay";
	bus-width = <4>;
	broken-cd;
};

&otg {
	status = "okay";
	dr_mode = "peripheral";		/* gadget bind for DFU/g_dnl */
};

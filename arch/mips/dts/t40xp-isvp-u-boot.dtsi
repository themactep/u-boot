// SPDX-License-Identifier: GPL-2.0+
/*
 * Binman image description for the Ingenic ISVP-T40XP SFC-NAND boot.
 *
 * T40XP uses SPI-NAND (DDR3 256 MiB, vs T40NN's DDR2 NOR + 128 MiB).
 * The bootrom's NAND boot path expects no INGE block at SPL offset
 * 0x100 (vendor SPI-NAND SPL ships with all zeros there). Since the
 * etype now defaults to no-INGE (only emits when
 * `ingenic,inge-descriptors` is supplied), we simply omit
 * descriptors. The `ingenic,no-inge` boolean below is retained as
 * the NAND-style 64-byte block alignment switch (the vendor
 * `spl_pad_to_block.c` rule for the secure-boot hash module).
 *
 * The custom NAND U-Boot loader in arch/mips/mach-xburst/t40/sfc_nand.c
 * reads the legacy mkimage header + LZMA payload from NAND offset
 * T40_NAND_UBOOT_OFFSET (0x80000), so keep U-Boot at 0x80000 here.
 * The 64 KiB SPL window is comfortable for DM-in-SPL builds.
 *
 * `ingenic,min-spl-length` covers the BSS region: with DM-in-SPL the
 * SPL ends before SPL_BSS_START_ADDR + SPL_BSS_MAX_SIZE = 0x80016000,
 * so we pad the SPL file (with 0xff) to that length, so the bootrom
 * caches enough SRAM to back BSS during board_init_f.
 */

/ {
	binman: binman {
		multiple-images;
	};
};

&binman {
	u-boot-spl-t40xp {
		filename = "u-boot-spl-t40xp.bin";

		ingenic-t31-spl {
			filename = "spl/u-boot-spl.bin";
			ingenic,no-inge;
			ingenic,min-spl-length = <0x16000>;
		};
	};

	flash {
		filename = "u-boot-with-spl-lzma.bin";
		pad-byte = <0xff>;

		spl {
			type = "blob";
			offset = <0x0>;
			filename = "u-boot-spl-t40xp.bin";
		};

		u-boot {
			type = "blob";
			offset = <0x80000>;
			filename = "u-boot-lzma.img";
		};
	};
};

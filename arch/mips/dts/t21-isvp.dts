/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include "t21.dtsi"

/ {
	compatible = "ingenic,isvp-t21", "ingenic,t21";
	model = "Ingenic ISVP-T21 (DDR2 64M, SFC NOR)";

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory {
		device_type = "memory";
		reg = <0x0 0x04000000>;	/* 64 MB DDR2 (T21N) */
	};
};

&uart1 {
	status = "okay";
};

&sfc {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

&msc0 {
	status = "okay";
	bus-width = <4>;
	broken-cd;	/* no card-detect line wired on the ISVP board */
};

&gmac {
	status = "okay";
	/* PHY reset GPIO; exact pin varies per board, override per device. */
	ingenic,reset-gpio = <&gpb 28 GPIO_ACTIVE_LOW>;
};

&otg {
	status = "okay";
};

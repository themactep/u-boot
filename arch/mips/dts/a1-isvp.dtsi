// SPDX-License-Identifier: GPL-2.0+
/*
 * Ingenic ISVP-A1 board body, shared by every A1 SKU. The per-SKU
 * leaf .dts (a1n-isvp.dts, ...) includes this file and sets the
 * per-SKU compatible on &ddr. A1 is SFC-NOR only today; if a NAND A1
 * board appears, split the flash node into boot-media fragments like
 * T40.
 */

#include <dt-bindings/clock/ingenic,a1-cgu.h>

/ {
	compatible = "ingenic,a1";
	#address-cells = <1>;
	#size-cells = <1>;

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x10000000>;
	};

	ddr: memory-controller@b34f0000 {
		reg = <0xb34f0000 0x3000>;
		/* compatible is set by the per-SKU leaf .dts. */
		bootph-all;
	};

	cgu: clock-controller@b0000000 {
		compatible = "ingenic,a1-cgu";
		reg = <0xb0000000 0x1000>;
		#clock-cells = <1>;
		bootph-all;
	};

	pinctrl: pinctrl@b0010000 {
		compatible = "ingenic,a1-pinctrl";
		reg = <0xb0010000 0x8000>;
		#address-cells = <1>;
		#size-cells = <0>;
		bootph-all;

		gpa: gpio@0 {
			compatible = "ingenic,a1-gpio";
			reg = <0>;
			gpio-controller;
			#gpio-cells = <2>;
			bootph-all;
		};

		gpb: gpio@1 {
			compatible = "ingenic,a1-gpio";
			reg = <1>;
			gpio-controller;
			#gpio-cells = <2>;
			bootph-all;
		};

		gpc: gpio@2 {
			compatible = "ingenic,a1-gpio";
			reg = <2>;
			gpio-controller;
			#gpio-cells = <2>;
			bootph-all;
		};

		gpd: gpio@3 {
			compatible = "ingenic,a1-gpio";
			reg = <3>;
			gpio-controller;
			#gpio-cells = <2>;
			bootph-all;
		};

		gpe: gpio@4 {
			compatible = "ingenic,a1-gpio";
			reg = <4>;
			gpio-controller;
			#gpio-cells = <2>;
			bootph-all;
		};

		pins_uart1: uart1 {
			function = "uart1";
			groups = "uart1-data";
			bootph-all;
		};

		pins_sfc: sfc {
			function = "sfc";
			groups = "sfc-data";
			bootph-all;
		};

		pins_mac0: mac0 {
			function = "mac0";
			groups = "mac0-data";
		};
	};

	uart1: serial@b0031000 {
		compatible = "ingenic,jz4780-uart", "ns16550a";
		reg = <0xb0031000 0x100>;
		reg-shift = <2>;
		clock-frequency = <24000000>;
		pinctrl-names = "default";
		pinctrl-0 = <&pins_uart1>;
		status = "okay";
		bootph-all;
	};

	/*
	 * TCU (timer/counter unit) container mirroring T31/T41's binding.
	 * U-Boot only needs the watchdog child for sysreset; the WDT
	 * self-clocks from the 32 kHz RTC so no TCU clock provider is
	 * required. Replaces the hand-rolled a1/soc.c _machine_restart().
	 */
	tcu: timer@b0002000 {
		compatible = "ingenic,a1-tcu", "ingenic,jz4760-tcu",
			     "simple-mfd";
		reg = <0xb0002000 0x1000>;
		#address-cells = <1>;
		#size-cells = <1>;
		ranges = <0x0 0xb0002000 0x1000>;

		watchdog: watchdog@0 {
			compatible = "ingenic,a1-watchdog",
				     "ingenic,jz4780-watchdog";
			reg = <0x0 0x10>;
		};
	};

	/*
	 * AIC (audio interface controller) + on-chip codec. PIO/DMA playback
	 * driven by U-Boot's `sound` command, handled by the self-contained
	 * drivers/sound/a1_audio.c (the A1 codec is its own register block at
	 * 0xb0022000, distinct from T41's; the AIC is T41-like). Addresses
	 * confirmed against the A1-1.7.0 kernel soc/base.h.
	 */
	aic: audio-controller@b0020000 {
		compatible = "ingenic,a1-aic";
		reg = <0xb0020000 0x100>;
		clocks = <&cgu A1_CLK_APLL>;
		clock-names = "apll";
		#sound-dai-cells = <0>;
		status = "okay";
	};

	codec: audio-codec@b0022000 {
		compatible = "ingenic,a1-codec";
		reg = <0xb0022000 0x140>;
		#sound-dai-cells = <0>;
		status = "okay";
	};

	sound: sound {
		compatible = "ingenic,a1-sound";
		status = "okay";

		cpu {
			sound-dai = <&aic>;
		};

		codec {
			sound-dai = <&codec>;
		};
	};

	sfc: spi@b3440000 {
		compatible = "ingenic,a1-sfc";
		reg = <0xb3440000 0x10000>;
		#address-cells = <1>;
		#size-cells = <0>;
		clocks = <&cgu A1_CLK_SFC>;
		pinctrl-names = "default";
		pinctrl-0 = <&pins_sfc>;
		spi-max-frequency = <50000000>;
		status = "okay";
		bootph-all;

		flash@0 {
			compatible = "jedec,spi-nor";
			reg = <0>;
			spi-max-frequency = <50000000>;
			bootph-all;
		};
	};

	gmac0: ethernet@b30b0000 {
		compatible = "ingenic,a1-gmac";
		reg = <0xb30b0000 0x10000>;
		clocks = <&cgu A1_CLK_GMAC0>;
		phy-mode = "rmii";
		phy-handle = <&gmac0_phy>;
		ingenic,mode-reg = <0xb00000c8>;
		max-speed = <100>;
		pinctrl-names = "default";
		pinctrl-0 = <&pins_mac0>;
		status = "okay";

		mdio {
			#address-cells = <1>;
			#size-cells = <0>;

			gmac0_phy: ethernet-phy@0 {
				reg = <0>;
			};
		};
	};

	otg0: usb@b3600000 {
		compatible = "snps,dwc2";
		reg = <0xb3600000 0x40000>;
		clocks = <&cgu A1_CLK_OTG0>;
		dr_mode = "host";
		status = "okay";
	};

	otg1: usb@b3640000 {
		compatible = "snps,dwc2";
		reg = <0xb3640000 0x40000>;
		clocks = <&cgu A1_CLK_OTG1>;
		dr_mode = "host";
		status = "okay";
	};

	otg2: usb@b3680000 {
		compatible = "snps,dwc2";
		reg = <0xb3680000 0x40000>;
		clocks = <&cgu A1_CLK_OTG2>;
		dr_mode = "host";
		status = "okay";
	};
};

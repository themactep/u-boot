/*
 * Ingenic ISVP-T31 shared DFU/USB-boot board body.
 *
 * Identical to t31-isvp.dtsi except the DWC2 OTG is dr_mode =
 * "peripheral" so the dwc2_udc_otg gadget binds (dwc2_udc_otg_bind
 * rejects "host"). Used by the usbboot defconfigs - the dev/flash
 * loader that USB-boots and auto-enters DFU. Production NOR uses
 * t31-isvp.dtsi (dr_mode="host" for USB host + USB-NIC).
 *
 * The per-SKU leaf .dts files (t31l-isvp-dfu.dts, t31a-isvp-dfu.dts)
 * include this and supply the DDR node's per-SKU "ingenic,sdram-params" array; the matching
 * <leaf>-u-boot.dtsi pulls in t31-isvp-dfu-uboot-common.dtsi.
 */

#include <dt-bindings/gpio/gpio.h>
#include "t31.dtsi"

/ {
	compatible = "ingenic,isvp-t31", "ingenic,t31";
	model = "Ingenic ISVP-T31 (DFU loader)";

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory {
		device_type = "memory";
		/* Placeholder; the DDR driver reports the real per-SKU size. */
		reg = <0x0 0x08000000>;
	};
};

&uart1 {
	status = "okay";
};

&sfc {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

&msc0 {
	status = "okay";
	bus-width = <4>;
	broken-cd;
};

&otg {
	status = "okay";
	dr_mode = "peripheral";		/* gadget bind for DFU/g_dnl */
};

/*
 * Ingenic ISVP-T30 shared DFU/USB-boot board body.
 *
 * Identical to t30-isvp.dtsi except the DWC2 OTG is dr_mode =
 * "peripheral" so the dwc2_udc_otg gadget binds, and the audio nodes
 * stay off. Used by the usbboot defconfig. Production NOR uses
 * t30-isvp.dtsi (dr_mode="host").
 *
 * The per-SKU leaf .dts files (t30l-isvp-dfu.dts, ...) include this
 * and set the DDR node's per-SKU compatible; the matching
 * <leaf>-u-boot.dtsi pulls in t30-isvp-dfu-uboot-common.dtsi.
 */

#include <dt-bindings/gpio/gpio.h>
#include "t30.dtsi"

/ {
	compatible = "ingenic,isvp-t30", "ingenic,t30";
	model = "Ingenic ISVP-T30 (DFU loader)";

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory {
		device_type = "memory";
		reg = <0x0 0x04000000>;	/* 64 MB DDR2 (T30N) */
	};
};

&uart1 {
	status = "okay";
};

&sfc {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

&msc0 {
	status = "okay";
	bus-width = <4>;
	broken-cd;
};

&otg {
	status = "okay";
	dr_mode = "peripheral";		/* gadget bind for DFU/g_dnl */
};

/*
 * Ingenic ISVP-T20 shared board body (SFC-NOR, USB host).
 *
 * The per-SKU leaf .dts files (t20n-isvp.dts, t20l-isvp.dts,
 * t20x-isvp.dts) include this and set the DDR node's per-SKU compatible
 * (ingenic,t20<sku>-ddr-dwc), which selects the variant table in the DWC
 * DDR driver. The matching <leaf>-u-boot.dtsi pulls in
 * t20-isvp-uboot-common.dtsi (binman image + SPL bootph).
 */

#include <dt-bindings/gpio/gpio.h>
#include "t20.dtsi"

/ {
	compatible = "ingenic,isvp-t20", "ingenic,t20";
	model = "Ingenic ISVP-T20 (SFC NOR)";

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory {
		device_type = "memory";
		reg = <0x0 0x04000000>;	/* 64 MB DDR2 (T20N); real size from dram_init */
	};
};

&uart1 {
	status = "okay";
};

&sfc {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

&msc0 {
	status = "okay";
	bus-width = <4>;
	broken-cd;	/* no card-detect line wired on the ISVP board */
};

&otg {
	status = "okay";
};

&aic {
	status = "okay";
};

&codec {
	status = "okay";
	ingenic,spk-gpio = <&gpb 31 GPIO_ACTIVE_HIGH>;
};

&sound {
	status = "okay";
};

/*
 * Ingenic ISVP-T32LQ DFU/USB-boot loader (DDR2 64 MB, CPU 900 MHz).
 *
 * The LQ DDR2-64M init brings up any DDR2 T32 part (LQ/VL/ZL are
 * param-identical), so this loader doubles as the universal DDR2 DFU
 * loader. DDR3/LPDDR3 parts (NQ/VN/XQ/VX/ZN/ZX/VNP) need their own
 * loader.
 */

/dts-v1/;

#include "t32-isvp-dfu.dtsi"

/ {
	model = "Ingenic ISVP-T32LQ (DFU loader)";
};

&ddr {
	compatible = "ingenic,t32lq-ddr-innophy";
};

/*
 * flash@0 declared spi-nand so the NAND stack binds on NAND boards.
 * board_late_init() (arch/mips/mach-xburst/dfu.c) auto-detects NOR vs
 * NAND: on a NOR board the spi-nand probe fails, the node is unbound,
 * and a SPI-NOR is probed on CS0 instead - one loader flashes either.
 */
&sfc {
	flash@0 {
		compatible = "spi-nand";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

/*
 * Ingenic ISVP-T20 shared DFU/USB-boot board body.
 *
 * Identical to t20-isvp.dtsi except the DWC2 OTG is dr_mode =
 * "peripheral" so the dwc2_udc_otg gadget binds, and the audio nodes stay
 * off. Used by the usbboot defconfig. Production NOR uses t20-isvp.dtsi
 * (dr_mode="host").
 *
 * The per-SKU leaf .dts files (t20l-isvp-dfu.dts, ...) include this and
 * set the DDR node's per-SKU compatible; the matching <leaf>-u-boot.dtsi
 * pulls in t20-isvp-dfu-uboot-common.dtsi.
 */

#include <dt-bindings/gpio/gpio.h>
#include "t20.dtsi"

/ {
	compatible = "ingenic,isvp-t20", "ingenic,t20";
	model = "Ingenic ISVP-T20 (DFU loader)";

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory {
		device_type = "memory";
		reg = <0x0 0x04000000>;	/* 64 MB DDR2 (T20L) */
	};
};

&uart1 {
	status = "okay";
};

&sfc {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

&msc0 {
	status = "okay";
	bus-width = <4>;
	broken-cd;
};

&otg {
	status = "okay";
	dr_mode = "peripheral";		/* gadget bind for DFU/g_dnl */
};

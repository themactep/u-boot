/*
 * Binman image description for the Ingenic ISVP-T40XP DFU loader.
 *
 * The USB-boot path uploads spl/u-boot-spl.bin + u-boot.bin directly
 * via the mask ROM (tools/t31-usbboot.py); the binman flash image
 * here is not used. Kept consistent with the SFC-NAND layout
 * (headered SPL at 0, LZMA U-Boot at 0x80000) so a stray 'make'
 * still produces a sensible flash image.
 */

/ {
	binman: binman {
		multiple-images;
	};
};

&binman {
	u-boot-spl-t40xp {
		filename = "u-boot-spl-t40xp.bin";

		ingenic-t31-spl {
			filename = "spl/u-boot-spl.bin";
			ingenic,no-inge;
			ingenic,min-spl-length = <0x16000>;
		};
	};

	flash {
		filename = "u-boot-with-spl-lzma.bin";
		pad-byte = <0xff>;

		spl {
			type = "blob";
			offset = <0x0>;
			filename = "u-boot-spl-t40xp.bin";
		};

		u-boot {
			type = "blob";
			offset = <0x80000>;
			filename = "u-boot-lzma.img";
		};
	};
};

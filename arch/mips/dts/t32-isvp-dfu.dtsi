/*
 * Ingenic ISVP-T32 shared DFU/USB-boot board body.
 *
 * Identical to t32-isvp.dtsi except the DWC2 OTG is dr_mode =
 * "peripheral" so the dwc2_udc_otg gadget binds (dwc2_udc_otg_bind
 * rejects "host"), and the audio nodes stay off. Used by the usbboot
 * defconfigs - the dev/flash loader that USB-boots and auto-enters
 * DFU. Production NOR uses t32-isvp.dtsi (dr_mode="host" for USB
 * host + USB-NIC).
 *
 * The per-SKU leaf .dts files (t32lq-isvp-dfu.dts, ...) include this
 * and set the DDR node's per-SKU compatible; the matching
 * <leaf>-u-boot.dtsi pulls in t32-isvp-dfu-uboot-common.dtsi.
 */

#include <dt-bindings/gpio/gpio.h>
#include "t32.dtsi"

/ {
	compatible = "ingenic,isvp-t32", "ingenic,t32";
	model = "Ingenic ISVP-T32 (DFU loader)";

	aliases {
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial1:115200n8";
	};

	memory {
		device_type = "memory";
		/* Placeholder; the DDR driver reports the real per-SKU size. */
		reg = <0x0 0x04000000>;
	};
};

&uart1 {
	status = "okay";
};

&sfc {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
};

&msc0 {
	status = "okay";
};

&otg {
	status = "okay";
	dr_mode = "peripheral";		/* gadget bind for DFU/g_dnl */
};

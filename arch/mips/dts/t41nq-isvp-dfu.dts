/dts-v1/;
#include "t41-isvp-dfu.dtsi"

/ {
	model = "Ingenic ISVP-T41NQ (DFU loader)";
};

/* T41NQ: DDR3 W631GU6NG, 128 MiB. */
&ddr {
	ingenic,sdram-params = <
		0x00000000 0x00000000	/* type family */
		0x00000010 0x08000000 0x00000000	/* bus_width chip0_size chip1_size */
		0x53724e00 0x29b92700	/* mpll_hz ddr_hz */
		0x05b008b0 0x15d08890 0x059008b0	/* apll mpll vpll _mnod */
		0x02002a35 0x0000b092 0x00000000 0x000020f8 0x00002800 0x67aa0083	/* cfg ctrl dlmr mmap0 mmap1 refcnt */
		0x07120b08 0x0708060a 0x030a040a 0x19221805 0x00050054	/* timing1..5 */
		0x26001556 0x00000000 0x00000001 0x00000001	/* autosr_cnt autosr_en hregpro pregpro */
		0x11111111 0x00000113	/* cguc0 cguc1 */
		0x0000000a 0x0000000a 0x00000008	/* memcfg cl cwl */
		0x00001d50 0x00010006 0x00020018 0x00030000 0x00000000 0x00000000	/* mr0 mr1 mr2 mr3 mr10 mr63 */
		0x030e0d0c 0x07060504 0x0b0a0908 0x0f020100 0x13121110	/* remap1..5 */
		0x00000000 0x00000000 0x0000000f 0x0000000f 0x00000003 0x00000003 0x00000014 0x00000014 0x0000008b 0x00000000 0x00000001 0x00000002 0x00000011 0x00000011 0x0000000a 0x00000008 0x00000008 0x0000000a 0x00000003	/* par[19] (efuse drive/ODT/skew) */
	>;
};

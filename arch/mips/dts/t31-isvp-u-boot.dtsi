// SPDX-License-Identifier: GPL-2.0+
/*
 * Binman image description for the Ingenic ISVP-T31 SFC-NOR boot.
 *
 * The T31 mask ROM boots from SPI-NOR by reading a headered SPL at
 * flash offset 0, which then loads U-Boot proper from a fixed offset.
 * This builds both pieces with 'make':
 *
 *   u-boot-spl-t31.bin : SPL with the finalized SFC-NOR boot header
 *                        (CRC7 + image length), bootable on its own
 *                        and equivalent to tools/mkt31spl.c output.
 *   u-boot-t31.bin     : full 16 MB flash image, headered SPL at
 *                        offset 0 and the LZMA U-Boot at 0x10000,
 *                        0xff-padded to the chip size.
 *   u-boot-t31-min.bin : same layout but trimmed to the end of the
 *                        U-Boot blob (~270 KB) - flash this at
 *                        offset 0 and leave the rest of the chip
 *                        untouched (erased flash already reads 0xff).
 */

/ {
	binman: binman {
		multiple-images;
	};
};

&binman {
	/*
	 * Standalone headered SPL: take the freshly built
	 * spl/u-boot-spl.bin through the T31 boot-header finalizer.
	 */
	u-boot-spl-t31 {
		filename = "u-boot-spl-t31.bin";

		ingenic-t31-spl {
			filename = "spl/u-boot-spl.bin";
		};
	};

	/*
	 * Combined 16 MB SFC-NOR flash image: headered SPL at offset 0,
	 * U-Boot proper at 0x8000 (SPL is ~17 KB / MAX_SIZE 0x5800, so
	 * 32 KB clears it with margin - no 0x10000 gap). Erased flash
	 * reads as 0xff. The SPL loader (t31/sfc.c T31_UBOOT_OFFSET)
	 * MUST match this offset.
	 */
	flash {
		filename = "u-boot-t31.bin";
		pad-byte = <0xff>;
		size = <0x1000000>;

		spl {
			type = "blob";
			offset = <0x0>;
			filename = "u-boot-spl-t31.bin";
		};

		/*
		 * LZMA-compressed U-Boot proper inside a legacy mkimage
		 * header; the SPL parses the header and decompresses to
		 * CONFIG_TEXT_BASE. ~3.5x smaller than raw u-boot.bin.
		 */
		u-boot {
			type = "blob";
			offset = <0x8000>;
			filename = "u-boot-lzma.img";
		};
	};

	/*
	 * Trimmed flashable image: identical layout (headered SPL @ 0,
	 * LZMA U-Boot @ 0x8000) but no chip-size padding - binman sizes
	 * it to the end of the last entry. Flash at offset 0.
	 */
	flash-min {
		filename = "u-boot-t31-min.bin";
		pad-byte = <0xff>;

		spl {
			type = "blob";
			offset = <0x0>;
			filename = "u-boot-spl-t31.bin";
		};

		u-boot {
			type = "blob";
			offset = <0x8000>;
			filename = "u-boot-lzma.img";
		};
	};
};

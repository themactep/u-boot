// SPDX-License-Identifier: GPL-2.0+
/*
 * Binman image description for the Ingenic ISVP-T31 SFC-NOR boot.
 *
 * The T31 mask ROM boots from SPI-NOR by reading a headered SPL at
 * flash offset 0, which then loads U-Boot proper from a fixed offset.
 * This builds both pieces with 'make':
 *
 *   u-boot-spl-t31.bin       : SPL with the finalized SFC-NOR boot
 *                              header (CRC7 + image length), bootable
 *                              standalone (equiv. to tools/mkt31spl.c).
 *   u-boot-with-spl-lzma.bin : headered SPL at offset 0 + LZMA U-Boot
 *                              at 0x8000 (the SPL loader's
 *                              T31_UBOOT_OFFSET in t31/sfc.c), trimmed
 *                              (no 0xff padding) - flash at offset 0;
 *                              erased flash already reads 0xff.
 */

/ {
	binman: binman {
		multiple-images;
	};
};

&binman {
	/*
	 * Standalone headered SPL: take the freshly built
	 * spl/u-boot-spl.bin through the T31 boot-header finalizer.
	 */
	u-boot-spl-t31 {
		filename = "u-boot-spl-t31.bin";

		ingenic-t31-spl {
			filename = "spl/u-boot-spl.bin";
			/*
			 * T31 mask ROM SFC NOR path does NOT consume an INGE
			 * block at 0x100. If INGE magic is present there the
			 * bootrom rejects the image (silent UART, no
			 * fallback). The etype writes an INGE block by
			 * default for T40/T41-style images; suppress it for
			 * T31. Empirically: cold boot worked at commit
			 * 3cc0f03ab574 when the etype emitted NO INGE
			 * (image[0x100] = 0x0000_0000); subsequent etype
			 * changes that began writing INGE unconditionally
			 * regressed T31 cold boot to silent.
			 */
			ingenic,no-inge;
		};
	};

	/*
	 * Combined SFC-NOR flash image: headered SPL at offset 0, LZMA
	 * U-Boot at 0x8000 (SPL ~17 KB / MAX_SIZE 0x5800; 32 KB clears
	 * it with margin - no 0x10000 gap). Trimmed to the end of the
	 * last entry; erased flash reads 0xff so the rest of the chip
	 * is fine to leave alone after flashing at offset 0.
	 */
	flash {
		filename = "u-boot-with-spl-lzma.bin";
		pad-byte = <0xff>;

		spl {
			type = "blob";
			offset = <0x0>;
			filename = "u-boot-spl-t31.bin";
		};

		u-boot {
			type = "blob";
			offset = <0x8000>;
			filename = "u-boot-lzma.img";
		};
	};
};

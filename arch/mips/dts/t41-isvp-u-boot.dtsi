// SPDX-License-Identifier: GPL-2.0+
/*
 * Binman image description for the Ingenic ISVP-T41 SFC-NOR boot.
 *
 * Mirrors the T40 SFC-NOR binman layout - T41 is the XBurst2 sibling of
 * T40 and uses the same vendor `0x03040506 / 0x55aa5502 / 0x000000aa`
 * SFC-NOR boot header at flash offset 0, with LZMA U-Boot at 0x10000
 * (the DM-in-SPL SPL is ~62 KiB, past the old 0x8000 ceiling).
 *
 * The SPL header is a plain CRC + SPL_LENGTH header (no INGE block).
 * Earlier T41 builds carried an `ingenic,inge-descriptors` table to
 * program PLLs/CPCCR/SFC before SPL entry; with DM-in-SPL the SPL sets
 * its own clocks in board_init_f before any clock-dependent work, so
 * the INGE pre-programming is redundant. HW-verified 2026-05-28: T41NQ
 * cold-boots cleanly to U-Boot without it (the only difference is a
 * single pre-clk 0x00 byte on the UART before the SPL's clk driver
 * runs). See the etype for the dormant opt-in property.
 *
 * 'make' produces:
 *   u-boot-spl-t41.bin       : SPL with the finalized SFC-NOR boot
 *                              header.
 *   u-boot-with-spl-lzma.bin : headered SPL at offset 0 + LZMA U-Boot
 *                              at 0x10000 - flash at offset 0 of NOR.
 */

/ {
	binman: binman {
		multiple-images;
	};
};

&binman {
	u-boot-spl-t41 {
		filename = "u-boot-spl-t41.bin";

		ingenic-t31-spl {
			filename = "spl/u-boot-spl.bin";
		};
	};

	flash {
		filename = "u-boot-with-spl-lzma.bin";
		pad-byte = <0xff>;

		spl {
			type = "blob";
			offset = <0x0>;
			filename = "u-boot-spl-t41.bin";
		};

		u-boot {
			type = "blob";
			offset = <0x14000>;
			filename = "u-boot-lzma.img";
		};
	};
};

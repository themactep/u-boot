/*
 * Ingenic ISVP-T30X (DDR2 128 MB M14D1G1664A, CPU 864 MHz), SFC-NOR.
 */

/dts-v1/;

#include "t30-isvp.dtsi"

/ {
	model = "Ingenic ISVP-T30X (SFC NOR)";
};

&ddr {
	/* T30X: DDR2 128 MB M14D1G1664A (8-bank), CPU 864 / DDR 500 MHz. */
	ingenic,sdram-params = <
		0x04704840 0x07c08820 0x9a073310	/* APLL864 MPLL1000 CPCCR */
		0 0					/* ddr_cdr (MPLL/2); DDR2 */
		13 10 1 1 0 0				/* row col bank8 cs0 cs1 dw32 */
		0x08000000				/* 128 MB */
		0x0aa88a42 0x0000d91e			/* DDRC_CFG DDRC_CTRL */
		0x000020f8 0x00002800 0x00f20001	/* MMAP0 MMAP1 REFCNT */
		0x040e0806 0x02170807 0x2008051d	/* TIMING1..3 */
		0x1f240031 0xff060405 0x32170505	/* TIMING4..6 */
		0x00000e73				/* MR0 */
	>;
};

/ {
	memory {
		device_type = "memory";
		reg = <0x0 0x08000000>;	/* 128 MB DDR2 */
	};
};

/*
 * Ingenic ISVP-T23N-HP (DDR2 64 MB M14D5121632A, CPU 1400 MHz profile of T23N), SFC-NOR.
 */

/dts-v1/;

#include "t23-isvp.dtsi"

/ {
	model = "Ingenic ISVP-T23N-HP (SFC NOR)";
};

&ddr {
	/* T23N-HP: DDR2 64 MB M14D5121632A (4-bank), CPU 1400 / DDR 600 MHz. */
	ingenic,sdram-params = <
		0x15e0d100 0x06405100 0x9a0b5510	/* APLL1400 MPLL1200 CPCCR */
		0 0					/* ddr_cdr (MPLL/2); DDR2 */
		13 10 0 1 0 0				/* row col bank8 cs0 cs1 dw32 */
		0x04000000				/* 64 MB */
		0x0a288a40 0x0000d91e			/* DDRC_CFG DDRC_CTRL */
		0x000020fc 0x00002400 0x00910003	/* MMAP0 MMAP1 REFCNT */
		0x050f0a06 0x021c0a07 0x200a0722	/* TIMING1..3 */
		0x26240031 0xff060405 0x321c0505	/* TIMING4..6 */
		0x00000f73				/* MR0 */
	>;
};

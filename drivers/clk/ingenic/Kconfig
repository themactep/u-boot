config CLK_INGENIC_A1
	bool "Ingenic A1 CGU clock driver"
	depends on CLK && ARCH_XBURST
	help
	  Clock driver for the Ingenic A1 (XBurst2) SoC Clock/Power
	  Manager (CGU). Same M/N/OD1/OD0 PLL encoding as the T-series;
	  the CGU register map differs (CLKGR0=0x30/CLKGR1=0x38,
	  dedicated SFC0 divider). Provides rate/gate control for the
	  leaf peripheral clocks (SFC, MMC, GMAC) that U-Boot drives.

config CLK_INGENIC_T10
	bool "Ingenic T10 CGU clock driver"
	depends on CLK && ARCH_XBURST
	help
	  Clock driver for the Ingenic T10 SoC Clock/Power Manager (CGU).
	  Same M/N/OD1/OD0 PLL encoding and CGU leaf map as T20 (SSI/MSC/
	  MAC PLL-select = single bit 31, ce/busy/stop = 29/28/27).
	  Provides rate/gate control for the leaf peripheral clocks (SFC,
	  MMC, GMAC) that U-Boot drives.

config CLK_INGENIC_T20
	bool "Ingenic T20 CGU clock driver"
	depends on CLK && ARCH_XBURST
	help
	  Clock driver for the Ingenic T20 SoC Clock/Power Manager (CGU).
	  T20 uses the T31/T23-style M/N/OD1/OD0 PLL encoding (NOT the
	  cpm_cpxpcr_t form of T21/T30). Provides rate/gate control for
	  the leaf peripheral clocks (SFC, MMC, GMAC) that U-Boot drives.

config CLK_INGENIC_T21
	bool "Ingenic T21 CGU clock driver"
	depends on CLK && ARCH_XBURST
	help
	  Clock driver for the Ingenic T21 SoC Clock/Power Manager (CGU).
	  Same XBurst1 leaf-clock CDR/gate map as T31 (with VPLL), but
	  the PLL register encoding differs (cpm_cpxpcr_t). Provides
	  rate/gate control for the leaf peripheral clocks (SFC, MMC,
	  GMAC) that U-Boot drives.

config CLK_INGENIC_T23
	bool "Ingenic T23 CGU clock driver"
	depends on CLK && ARCH_XBURST
	help
	  Clock driver for the Ingenic T23 SoC Clock/Power Manager (CGU).
	  Same XBurst1 CGU model as T31 (shared leaf-clock CDR/gate map)
	  minus the VPLL. Provides rate/gate control for the leaf
	  peripheral clocks (SFC, MMC, GMAC) that U-Boot drives.

config CLK_INGENIC_T30
	bool "Ingenic T30 CGU clock driver"
	depends on CLK && ARCH_XBURST
	help
	  Clock driver for the Ingenic T30 SoC Clock/Power Manager (CGU).
	  Same cpm_cpxpcr_t PLL + XBurst1 leaf-clock map as T21 (with
	  VPLL). Provides rate/gate control for the leaf peripheral
	  clocks (SFC, MMC, GMAC) that U-Boot drives.

config CLK_INGENIC_T31
	bool "Ingenic T31 CGU clock driver"
	depends on CLK && ARCH_XBURST
	help
	  Clock driver for the Ingenic T31 SoC Clock/Power Manager (CGU).
	  Recalculates the PLL rates programmed by the SPL and provides
	  rate/gate control for the leaf peripheral clocks (SFC, MMC,
	  GMAC) that U-Boot drives.

config CLK_INGENIC_T32
	bool "Ingenic T32 CGU clock driver"
	depends on CLK && ARCH_XBURST
	help
	  Clock driver for the Ingenic T32 (PRJ007) SoC Clock/Power
	  Manager. Same CGU register model as T33 (dedicated SFC0
	  divider, ce/busy/stop = 29/28/27, CLKGR* gate map); the leaf
	  rates are recomputed from the CPM PLL registers at runtime so
	  the driver is shared-structure with clk-t33. Provides rate/
	  gate control for SFC, MMC and GMAC.

config CLK_INGENIC_T33
	bool "Ingenic T33 CGU clock driver"
	depends on CLK && ARCH_XBURST
	help
	  Clock driver for the Ingenic T33 (PRJ008) SoC Clock/Power
	  Manager. T33 is "T31-extended" but the CGU is not bit-compatible
	  (dedicated SFC0 divider, ce/busy/stop = 29/28/27, different
	  CLKGR* gate map). Provides rate/gate control for the leaf
	  peripheral clocks (SFC, MMC, GMAC) that U-Boot drives.

config CLK_INGENIC_T40
	bool "Ingenic T40 CGU clock driver"
	depends on CLK && ARCH_XBURST
	help
	  Clock driver for the Ingenic T40 (XBurst2) SoC Clock/Power
	  Manager (CGU). Initial cut is structurally identical to A1
	  (same XBurst2 CGU layout) with T40-specific register offsets
	  in mach/t40.h. Will diverge as T40-specific peripherals get
	  wired up.
